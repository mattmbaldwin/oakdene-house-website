---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import InfoTable from '../components/InfoTable.astro';
import CTABand from '../components/CTABand.astro';

const hoursRows = [
  { label: 'Oakdene Kitchen',       value: 'Tuesday–Thursday, 12pm–2pm' },
  { label: 'Staple Food Packs',     value: 'Every Friday, 12pm–2pm (commencing 17 April 2026)' },
  { label: 'Oakdene Laundrette',    value: 'Tuesday–Thursday, 12pm–2:30pm (last entry 1pm)' },
  { label: 'Used Clothing Store',   value: 'Tuesday–Thursday, 12pm–2pm' },
  { label: 'Ladies Boutique',       value: 'Tuesday and Thursday, 10am–4pm (by appointment)' },
  { label: 'Counselling',           value: 'By appointment' },
  { label: 'Life Choices Program',  value: 'See <a href="/services/life-choices-program/">program page</a> for full schedule' },
];

const contactCards = [
  {
    icon: 'phone',
    heading: 'Phone',
    detail: '(02) 8717 0999',
    href: 'tel:0287170999',
    note: 'Give us a call during business hours',
  },
  {
    icon: 'email',
    heading: 'Email',
    detail: 'admin@oakdenehouse.org.au',
    href: 'mailto:admin@oakdenehouse.org.au',
    note: 'Send us an email and we will get back to you',
  },
  {
    icon: 'map',
    heading: 'Visit Us',
    detail: '29 Vine St, Fairfield NSW 2165',
    href: null,
    note: 'Parking via Fairfield RSL open air car park, corner of Vine and Bertha Streets',
  },
  {
    icon: 'clock',
    heading: 'Opening Hours',
    detail: 'Monday–Friday',
    href: null,
    note: 'Hours to be confirmed with the Oakdene team',
  },
];
---

<BaseLayout
  title="Contact Us | Oakdene House Foundation"
  description="Get in touch with Oakdene House Foundation in Fairfield, Western Sydney. Call (02) 8717 0999 or email admin@oakdenehouse.org.au"
  ogImage="/images/centre/exterior-exterior-1-img_2651.jpg"
>

  <!-- HERO -->
  <Hero
    heading="Contact Oakdene House Foundation"
    subheading="Whether you are looking for support, information, a referral pathway, or community connection — we are here to help."
    image="/images/centre/exterior-exterior-2-img_2649-with-people.png"
    imageAlt="Oakdene House Foundation centre exterior"
    buttons={[
      { text: 'Need Help Now', href: '/need-help-now/', variant: 'white-outline' },
    ]}
  />

  <!-- CONTACT CARDS -->
  <section class="section" aria-labelledby="contact-options-heading">
    <div class="container">
      <h2 id="contact-options-heading" class="visually-hidden">Contact options</h2>
      <div class="contact-cards">

        <div class="contact-card">
          <div class="contact-card__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.09 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 5.98 5.98l1.28-1.28a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.02z"/></svg>
          </div>
          <p class="contact-card__heading">Phone</p>
          <a href="tel:0287170999" class="contact-card__detail">(02) 8717 0999</a>
          <p class="contact-card__note">Give us a call during business hours</p>
        </div>

        <div class="contact-card">
          <div class="contact-card__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <p class="contact-card__heading">Email</p>
          <a href="mailto:admin@oakdenehouse.org.au" class="contact-card__detail contact-card__detail--small">admin@oakdenehouse.org.au</a>
          <p class="contact-card__note">Send us an email and we will get back to you</p>
        </div>

        <div class="contact-card">
          <div class="contact-card__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <p class="contact-card__heading">Visit Us</p>
          <p class="contact-card__detail contact-card__detail--small">29 Vine St, Fairfield NSW 2165</p>
          <p class="contact-card__note">Parking via Fairfield RSL open air car park, corner of Vine and Bertha Streets</p>
        </div>

        <div class="contact-card">
          <div class="contact-card__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <p class="contact-card__heading">Opening Hours</p>
          <p class="contact-card__detail contact-card__detail--small">Monday to Friday</p>
          <p class="contact-card__note">9:00am – 5:00pm</p>
        </div>

      </div>
    </div>
  </section>

  <!-- SERVICE-SPECIFIC CONTACTS -->
  <section class="section section--tint" aria-labelledby="service-contacts-heading">
    <div class="container">
      <div class="section-heading">
        <p class="section-heading__eyebrow">Service Contacts</p>
        <h2 id="service-contacts-heading">Service-specific contacts</h2>
      </div>
      <div class="service-contacts">
        <div class="service-contact-card">
          <h3>Kitchen, Food Packs, Laundrette &amp; Used Clothing Store</h3>
          <div class="service-contact-card__links">
            <a href="mailto:kitchen@oakdenehouse.org.au">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              kitchen@oakdenehouse.org.au
            </a>
            <a href="tel:0415156100">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.09 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 5.98 5.98l1.28-1.28a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.02z"/></svg>
              0415 156 100
            </a>
          </div>
        </div>
        <div class="service-contact-card">
          <h3>Ladies Boutique</h3>
          <div class="service-contact-card__links">
            <a href="mailto:boutique@oakdenehouse.org.au">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              boutique@oakdenehouse.org.au
            </a>
            <a href="tel:0415156100">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.09 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 5.98 5.98l1.28-1.28a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.02z"/></svg>
              0415 156 100
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICE HOURS -->
  <section class="section" aria-labelledby="hours-heading">
    <div class="container hours-container">
      <div class="section-heading">
        <p class="section-heading__eyebrow">When We're Open</p>
        <h2 id="hours-heading">Service hours</h2>
      </div>
      <InfoTable rows={hoursRows} />
    </div>
  </section>

  <!-- LANGUAGE SUPPORT + POSTAL + ABN -->
  <section class="section section--tint" aria-labelledby="extra-info-heading">
    <div class="container">
      <h2 id="extra-info-heading" class="visually-hidden">Additional information</h2>
      <div class="extra-info-grid">

        <div class="extra-info-card">
          <div class="extra-info-card__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h3>Language Support</h3>
          <p>We offer support in multiple languages. If you need an interpreter, please let us know when you contact us and we will arrange one for you.</p>
        </div>

        <div class="extra-info-card">
          <div class="extra-info-card__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.09 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 5.98 5.98l1.28-1.28a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.02z"/></svg>
          </div>
          <h3>Postal Address</h3>
          <p>PO Box 988<br />Fairfield NSW 1860</p>
          <p class="abn-line">ABN: 90 151 950 926 &nbsp;|&nbsp; Registered Charity</p>
        </div>

      </div>
    </div>
  </section>

  <!-- MAP -->
  <section class="section" aria-labelledby="map-heading">
    <div class="container">
      <div class="section-heading">
        <p class="section-heading__eyebrow">Find Us</p>
        <h2 id="map-heading">Getting here</h2>
      </div>
      <iframe
        src="https://maps.google.com/maps?q=29+Vine+St+Fairfield+NSW+2165&output=embed&z=16"
        class="contact-map"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Map showing Oakdene House Foundation at 29 Vine Street, Fairfield NSW 2165"
        aria-label="Interactive map showing Oakdene House Foundation at 29 Vine Street, Fairfield NSW 2165"
      ></iframe>
      <div class="map-directions">
        <a
          href="https://www.google.com/maps/dir/?api=1&destination=29+Vine+St+Fairfield+NSW+2165"
          target="_blank"
          rel="noopener noreferrer"
          class="map-directions__link"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
          Get directions
        </a>
      </div>
    </div>
  </section>

  <!-- ENQUIRY FORM -->
  <section class="section section--tint" aria-labelledby="form-heading">
    <div class="container form-container">

      <h2 id="form-heading">We'd love to hear from you</h2>
      <p class="form-intro">Whether you're looking for support, interested in one of our programs, considering a partnership, or just want to know more about Oakdene — send us a message and we'll be in touch within 2 business days.</p>

      <!-- Success state -->
      <div class="form-success" id="form-success" hidden tabindex="-1">
        <p class="form-success__heading"><strong>Thanks — your message has been sent. We'll be in touch within 2 business days.</strong></p>
        <p>If you need support urgently, please call us on <a href="tel:+61287170999">(02) 8717 0999</a> during business hours, or visit our <a href="/need-help-now/">Need Help Now</a> page for 24/7 support.</p>
      </div>

      <!-- Form-level error banner (populated by JS; hidden via :empty when blank) -->
      <div class="form-error-banner" id="form-error-banner" role="alert" aria-live="assertive" tabindex="-1"></div>

      <form id="contact-form" class="contact-form" novalidate>

        <!-- Honeypot: hidden from sighted users and screen readers; bots fill it in -->
        <div class="contact-honeypot" aria-hidden="true">
          <label for="website">Leave this blank</label>
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <div class="form-row">
          <div class="form-field" id="field-first-name">
            <label for="first-name">First name <span class="form-field__req" aria-hidden="true">*</span></label>
            <input
              id="first-name"
              name="first_name"
              type="text"
              autocomplete="given-name"
              aria-required="true"
              aria-describedby="first-name-error"
            />
            <p class="form-field__error" id="first-name-error" role="alert"></p>
          </div>
          <div class="form-field" id="field-last-name">
            <label for="last-name">Last name <span class="form-field__req" aria-hidden="true">*</span></label>
            <input
              id="last-name"
              name="last_name"
              type="text"
              autocomplete="family-name"
              aria-required="true"
              aria-describedby="last-name-error"
            />
            <p class="form-field__error" id="last-name-error" role="alert"></p>
          </div>
        </div>

        <div class="form-row">
          <div class="form-field" id="field-email">
            <label for="email">Email <span class="form-field__req" aria-hidden="true">*</span></label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              aria-required="true"
              aria-describedby="email-error"
            />
            <p class="form-field__error" id="email-error" role="alert"></p>
          </div>
          <div class="form-field">
            <label for="phone">Phone <span class="form-field__optional">(optional)</span></label>
            <input
              id="phone"
              name="phone"
              type="tel"
              autocomplete="tel"
            />
          </div>
        </div>

        <div class="form-field" id="field-reason">
          <label for="reason">Reason for enquiry <span class="form-field__req" aria-hidden="true">*</span></label>
          <select
            id="reason"
            name="reason"
            aria-required="true"
            aria-describedby="reason-error"
          >
            <option value="" disabled selected>Select a reason…</option>
            <option value="general">General enquiry</option>
            <option value="counselling">Counselling or support</option>
            <option value="community-programs">Community programs</option>
            <option value="program-interest">Program interest — I'd like to join a program</option>
            <option value="volunteering">Volunteering</option>
            <option value="partnership">Partnership or organisation enquiry</option>
            <option value="donation">Donation or fundraising</option>
            <option value="media">Media enquiry</option>
            <option value="other">Other</option>
          </select>
          <p class="form-field__error" id="reason-error" role="alert"></p>
        </div>

        <div class="form-field" id="field-message">
          <label for="message">Message <span class="form-field__req" aria-hidden="true">*</span></label>
          <textarea
            id="message"
            name="message"
            rows="6"
            aria-required="true"
            aria-describedby="message-error"
          ></textarea>
          <p class="form-field__error" id="message-error" role="alert"></p>
        </div>

        <div class="form-field form-field--checkbox" id="field-consent">
          <div class="checkbox-wrapper">
            <input
              type="checkbox"
              id="consent"
              name="consent"
              aria-required="true"
              aria-describedby="consent-error"
            />
            <label for="consent">I understand my enquiry will be handled in line with Oakdene's <a href="/privacy-policy/">privacy policy</a>.</label>
          </div>
          <p class="form-field__error" id="consent-error" role="alert"></p>
        </div>

        <div class="form-actions">
          <button type="submit" id="submit-btn" class="btn btn--primary">Send message</button>
        </div>

      </form>
    </div>
  </section>

  <!-- CTA -->
  <CTABand
    heading="Need support right now?"
    subheading="If you need immediate help, visit our Need Help Now page for crisis lines and emergency contacts."
    primaryBtn={{ text: 'Need Help Now', href: '/need-help-now/' }}
    secondaryBtn={{ text: 'Get Support', href: '/contact/' }}
    dark={true}
  />

<script is:inline>
(function () {
  // URL pre-fill: ?reason=<slug> pre-selects the dropdown
  var validReasons = ['general','counselling','community-programs','program-interest',
    'volunteering','partnership','donation','media','other'];
  var slug = new URLSearchParams(window.location.search).get('reason');
  if (slug && validReasons.indexOf(slug) !== -1) {
    var sel = document.getElementById('reason');
    if (sel) sel.value = slug;
  }

  var form      = document.getElementById('contact-form');
  var submitBtn = document.getElementById('submit-btn');
  var successEl = document.getElementById('form-success');
  var errorBanner = document.getElementById('form-error-banner');
  if (!form) return;

  // Required field definitions
  var fields = [
    { id: 'first-name', wrId: 'field-first-name', errId: 'first-name-error', msg: 'Please enter your first name.'                     },
    { id: 'last-name',  wrId: 'field-last-name',  errId: 'last-name-error',  msg: 'Please enter your last name.'                      },
    { id: 'email',      wrId: 'field-email',       errId: 'email-error',      msg: 'Please enter a valid email address.'               },
    { id: 'reason',     wrId: 'field-reason',      errId: 'reason-error',     msg: 'Please select a reason for your enquiry.'          },
    { id: 'message',    wrId: 'field-message',     errId: 'message-error',    msg: 'Please enter a message.'                          },
    { id: 'consent',    wrId: 'field-consent',     errId: 'consent-error',    msg: 'Please confirm you have read the privacy policy.'  },
  ];

  function isValid(el) {
    if (el.type === 'checkbox') return el.checked;
    if (el.type === 'email')    return el.value.trim() !== '' && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(el.value);
    if (el.tagName === 'SELECT') return el.value !== '';
    return el.value.trim() !== '';
  }

  function setError(f, msg) {
    var el = document.getElementById(f.id);
    var wr = document.getElementById(f.wrId);
    var er = document.getElementById(f.errId);
    if (!el || !wr || !er) return;
    er.textContent = msg;
    wr.classList.add('form-field--error');
    el.setAttribute('aria-invalid', 'true');
  }

  function clearError(f) {
    var el = document.getElementById(f.id);
    var wr = document.getElementById(f.wrId);
    var er = document.getElementById(f.errId);
    if (!el || !wr || !er) return;
    er.textContent = '';
    wr.classList.remove('form-field--error');
    el.removeAttribute('aria-invalid');
  }

  function validate() {
    var first = null;
    fields.forEach(function (f) {
      var el = document.getElementById(f.id);
      if (!el) return;
      if (!isValid(el)) { setError(f, f.msg); if (!first) first = el; }
      else clearError(f);
    });
    if (first) first.focus();
    return !first;
  }

  // Clear individual field errors as the user corrects them
  fields.forEach(function (f) {
    var el = document.getElementById(f.id);
    if (!el) return;
    var evts = el.type === 'checkbox' ? ['change'] : ['input', 'change'];
    evts.forEach(function (evt) {
      el.addEventListener(evt, function () { if (isValid(el)) clearError(f); });
    });
  });

  // Submit handler
  form.addEventListener('submit', async function (e) {
    e.preventDefault();
    errorBanner.innerHTML = '';

    if (!validate()) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending\u2026';

    var fd = new FormData(form);
    try {
      var res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          first_name: fd.get('first_name'),
          last_name:  fd.get('last_name'),
          email:      fd.get('email'),
          phone:      fd.get('phone') || '',
          reason:     fd.get('reason'),
          message:    fd.get('message'),
          website:    fd.get('website') || '',
        }),
      });

      if (!res.ok) throw new Error('non-200');

      form.style.display = 'none';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send message';
      successEl.hidden = false;
      successEl.focus();

    } catch (_) {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send message';
      errorBanner.innerHTML =
        'Sorry, something went wrong sending your message. Please call us on ' +
        '<a href="tel:+61287170999">(02)\u00a08717\u00a00999</a> or email ' +
        '<a href="mailto:admin@oakdenehouse.org.au">admin@oakdenehouse.org.au</a> ' +
        'and we\u2019ll get back to you.';
      errorBanner.focus();
    }
  });
}());
</script>
</BaseLayout>

<style>
  /* Contact cards */
  .contact-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .contact-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-secondary);
    border-radius: var(--radius-card);
    padding: 28px 24px;
    text-align: center;
    box-shadow: var(--shadow-card);
  }

  .contact-card__icon {
    color: var(--color-primary);
    margin-bottom: 14px;
    display: flex;
    justify-content: center;
  }

  .contact-card__heading {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 10px;
  }

  .contact-card__detail {
    display: block;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
    margin-bottom: 10px;
    transition: color var(--transition);
  }

  .contact-card__detail:hover {
    color: var(--color-primary-hover);
  }

  .contact-card__detail--small {
    font-size: 0.9375rem;
  }

  .contact-card__note {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin-bottom: 0;
  }

