---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABand from '../../components/CTABand.astro';
---

<BaseLayout
  title="Flyers and Brochures — Oakdene House Foundation"
  description="Oakdene House Foundation flyers and brochures. Contact us for printed materials."
>

  <section class="simple-hero" aria-label="Flyers and Brochures">
    <div class="container simple-hero__content">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <a href="/resources/">Resources</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span aria-current="page">Flyers and Brochures</span>
      </nav>
      <h1>Flyers and Brochures</h1>
      <p class="simple-hero__lead">Printed and digital materials about Oakdene House services.</p>
    </div>
  </section>

  <section class="section" aria-labelledby="flyers-heading">
    <div class="container">
      <div class="placeholder-content">
        <div class="placeholder-icon" aria-hidden="true">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </div>
        <h2 id="flyers-heading">Coming soon</h2>
        <p>Flyers and brochures will be available here. Please contact us if you need printed materials — we will be happy to help.</p>
        <div class="btn-group">
          <a href="/contact/" class="btn btn--primary">Contact Us</a>
          <a href="/resources/" class="btn btn--secondary">Back to Resources</a>
        </div>
      </div>
    </div>
  </section>

  <CTABand
    heading="Need printed materials?"
    subheading="Contact our team and we will arrange what you need."
    primaryBtn={{ text: 'Contact Us', href: '/contact/' }}
    dark={true}
  />

</BaseLayout>

<style>
  .simple-hero {
    background-color: var(--color-primary);
    padding-block: 64px 56px;
  }

  .simple-hero__content {
    max-width: 600px;
  }

  .simple-hero__content h1 {
    color: var(--color-white);
    margin-bottom: 10px;
  }

  .simple-hero__lead {
    font-size: 1.0625rem;
    color: rgba(255,255,255,0.85);
    margin-bottom: 0;
  }

  .placeholder-content {
    max-width: 560px;
    text-align: center;
    margin-inline: auto;
    padding: 48px 32px;
  }

  .placeholder-icon {
    color: var(--color-secondary);
    margin-bottom: 20px;
  }

  .placeholder-content h2 {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 14px;
  }

  .placeholder-content p {
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.7;
    margin-bottom: 28px;
  }
</style>
