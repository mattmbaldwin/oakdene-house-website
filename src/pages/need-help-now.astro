---
import BaseLayout from '../layouts/BaseLayout.astro';

const helplines = [
  {
    name: 'Lifeline',
    phone: '13 11 14',
    tel: '131114',
    description: '24/7 crisis and suicide prevention',
  },
  {
    name: 'Suicide Call Back Service',
    phone: '1300 659 467',
    tel: '1300659467',
    description: '24/7 for anyone affected by suicide',
  },
  {
    name: 'Beyond Blue',
    phone: '1300 22 4636',
    tel: '1300224636',
    description: '24/7 anxiety, depression, mental health',
  },
  {
    name: 'Kids Helpline',
    phone: '1800 55 1800',
    tel: '1800551800',
    description: '24/7 counselling for ages 5–25',
  },
  {
    name: 'MensLine Australia',
    phone: '1300 78 99 78',
    tel: '1300789978',
    description: '24/7 support for men',
  },
  {
    name: '13YARN',
    phone: '13 92 76',
    tel: '139276',
    description: '24/7 Aboriginal & Torres Strait Islander support',
  },
  {
    name: '1800RESPECT',
    phone: '1800 737 732',
    tel: '1800737732',
    description: '24/7 family and domestic violence',
  },
  {
    name: 'NSW Mental Health Line',
    phone: '1800 011 511',
    tel: '1800011511',
    description: '24/7 mental health triage',
  },
  {
    name: 'Gambling Help',
    phone: '1800 858 858',
    tel: '1800858858',
    description: '24/7 gambling counselling',
  },
  {
    name: 'AA Helpline',
    phone: '1300 222 222',
    tel: '1300222222',
    description: 'Alcoholics Anonymous',
  },
  {
    name: 'Salvo Connect',
    phone: '1300 36 36 22',
    tel: '1300363622',
    description: 'Emergency support and practical assistance',
  },
];
---

<BaseLayout
  title="Need Help Now? | Oakdene House Foundation"
  description="If you need support right now, help is available. Crisis lines, emergency contacts, and Oakdene House contact details."
>

  <!-- HERO — calm, no image -->
  <section class="help-hero" aria-label="Need help now">
    <div class="container help-hero__content">
      <h1>Need help right now?</h1>
      <p class="help-hero__lead">You are not alone. Help is available 24 hours a day.</p>
    </div>
  </section>

  <!-- EMERGENCY — 000 -->
  <section class="section emergency-section" aria-labelledby="emergency-heading">
    <div class="container">
      <div class="emergency-box" role="alert" aria-live="polite">
        <div class="emergency-box__icon" aria-hidden="true">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.09 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 5.98 5.98l1.28-1.28a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.02z"/></svg>
        </div>
        <div class="emergency-box__text">
          <p class="emergency-box__label" id="emergency-heading">If you are in immediate danger</p>
          <p class="emergency-box__number">Call <a href="tel:000">000</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- CRISIS HELPLINES -->
  <section class="section section--tint" aria-labelledby="helplines-heading">
    <div class="container">
      <div class="section-heading section-heading--center">
        <h2 id="helplines-heading">Crisis support lines</h2>
        <p class="section-heading__lead">These services are available around the clock, any day of the year.</p>
      </div>
      <div class="helplines-list" role="list">
        {helplines.map(line => (
          <div class="helpline-card" role="listitem">
            <div class="helpline-card__name">{line.name}</div>
            <div class="helpline-card__desc">{line.description}</div>
            <a href={`tel:${line.tel}`} class="helpline-card__phone" aria-label={`Call ${line.name} on ${line.phone}`}>
              {line.phone}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TALK TO OAKDENE -->
  <section class="section" aria-labelledby="oakdene-contact-heading">
    <div class="container">
      <div class="split">
        <div>
          <div class="section-heading">
            <h2 id="oakdene-contact-heading">Talk to Oakdene</h2>
          </div>
          <p>If you need to speak with someone at Oakdene during business hours, please call us directly. We can help connect you with the right support.</p>

          <a href="tel:0287170999" class="oakdene-phone" aria-label="Call Oakdene House Foundation on (02) 8717 0999">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.09 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 5.98 5.98l1.28-1.28a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.02z"/></svg>
            (02) 8717 0999
          </a>

          <p class="email-line">
            Email: <a href="mailto:admin@oakdenehouse.org.au">admin@oakdenehouse.org.au</a>
          </p>

          <p class="language-note">
            We also offer support in multiple languages. If you need an interpreter, please let us know when you call.
          </p>
        </div>
        <div class="contact-card-aside">
          <div class="hours-reminder">
            <h3>Business hours</h3>
            <p>Our team is available Monday to Friday during business hours.</p>
            <p>For outside-hours support please use the crisis lines listed on this page.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL NOTE -->
  <section class="section section--tint final-note-section" aria-label="Important note about Oakdene services">
    <div class="container final-note-container">
      <div class="final-note">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p>Oakdene House is not a crisis line. For immediate emergencies always call <strong>000</strong>. For 24-hour crisis support, please use the helplines above.</p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero — calm dark teal, no image */
  .help-hero {
    background-color: var(--color-primary);
    padding-block: 72px 64px;
  }

  .help-hero__content {
    max-width: 640px;
  }

  .help-hero__content h1 {
    color: var(--color-white);
    font-size: clamp(2rem, 5vw, 2.75rem);
    margin-bottom: 14px;
  }

  .help-hero__lead {
    font-size: 1.1875rem;
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.55;
    margin-bottom: 0;
  }

  /* Emergency */
  .emergency-section {
    padding-block: 48px;
  }

  .emergency-box {
    display: flex;
    align-items: center;
    gap: 24px;
    background-color: var(--color-white);
    border: 2px solid var(--color-primary);
    border-radius: var(--radius-card);
    padding: 28px 36px;
    max-width: 600px;
  }

  .emergency-box__icon {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .emergency-box__label {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
    margin-bottom: 4px;
  }

  .emergency-box__number {
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
    margin-bottom: 0;
  }

  .emergency-box__number a {
    color: inherit;
    text-decoration: none;
  }

  .emergency-box__number a:hover {
    text-decoration: underline;
  }

  /* Helplines */
  .helplines-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
    max-width: 760px;
    margin-inline: auto;
  }

  .helpline-card {
    display: grid;
    grid-template-columns: 220px 1fr auto;
    align-items: center;
    gap: 20px;
    background-color: var(--color-white);
    padding: 20px 24px;
    border-radius: var(--radius-card);
    border: 1px solid var(--color-secondary);
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .helpline-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card);
  }

  .helpline-card__name {
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-primary);
  }

  .helpline-card__desc {
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.4;
  }

  .helpline-card__phone {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
    white-space: nowrap;
    padding: 10px 20px;
    border: 2px solid var(--color-primary);
    border-radius: var(--radius-btn);
    transition: background-color var(--transition), color var(--transition);
  }

  .helpline-card__phone:hover {
    background-color: var(--color-primary);
    color: var(--color-white);
  }

  /* Talk to Oakdene */
  .oakdene-phone {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
    margin: 20px 0 16px;
    transition: color var(--transition);
  }

  .oakdene-phone:hover {
    color: var(--color-primary-hover);
  }

  .email-line {
    font-size: 1rem;
    color: var(--color-text);
    margin-bottom: 20px;
  }

  .email-line a {
    color: var(--color-primary);
    font-weight: 500;
  }

  .language-note {
    font-size: 0.9375rem;
    color: var(--color-muted);
    padding: 16px 20px;
    background-color: var(--color-tint);
    border-radius: var(--radius-btn);
    border-left: 3px solid var(--color-secondary);
    margin-bottom: 0;
  }

  /* Hours aside */
  .hours-reminder {
    background-color: var(--color-tint);
    border-radius: var(--radius-card);
    border: 1px solid var(--color-secondary);
    padding: 28px;
    height: 100%;
  }

  .hours-reminder h3 {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 12px;
  }

  .hours-reminder p {
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  /* Final note */
  .final-note-section {
    padding-block: 40px;
  }

  .final-note-container {
    max-width: 760px;
  }

  .final-note {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.6;
  }

  .final-note svg {
    color: var(--color-primary);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .final-note p {
    margin-bottom: 0;
  }

  /* Responsive */
  @media (max-width: 700px) {
    .helpline-card {
      grid-template-columns: 1fr;
      gap: 8px;
    }

    .helpline-card__phone {
      align-self: flex-start;
      font-size: 1rem;
    }

    .emergency-box {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
      padding: 24px;
    }
  }
</style>
