---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InfoTable from '../../components/InfoTable.astro';
import CTABand from '../../components/CTABand.astro';

const serviceRows = [
  { label: 'Cost', value: 'Free' },
  { label: 'Access', value: 'By appointment — no referral needed' },
  { label: 'Location', value: 'Oakdene Centre, 29 Vine Street, Fairfield' },
  { label: 'Phone', value: '<a href="tel:0287170999">(02) 8717 0999</a>' },
  { label: 'Email', value: '<a href="mailto:admin@oakdenehouse.org.au">admin@oakdenehouse.org.au</a>' },
];

---

<BaseLayout
  title="Financial Counselling — Oakdene House Foundation"
  description="Free financial counselling at Oakdene House for people experiencing hardship. Help with debt, bills, expenses and financial planning in Fairfield, Western Sydney."
  ogImage="/images/generic/bandw-business-man_distress.jpg"
>

  <!-- HERO -->
  <section class="fc-hero" aria-label="Financial Counselling">
    <div class="fc-hero__overlay" aria-hidden="true"></div>
    <div class="container fc-hero__content">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <a href="/services/">Services</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span aria-current="page">Financial Counselling</span>
      </nav>
      <h1>Financial Counselling</h1>
      <p class="fc-hero__lead">Free guidance for people experiencing financial hardship.</p>
    </div>
  </section>

  <!-- OVERVIEW -->
  <section class="section" aria-labelledby="fc-overview-heading">
    <div class="container">
      <div class="split">
        <div>
          <div class="section-heading">
            <p class="section-heading__eyebrow">The Service</p>
            <h2 id="fc-overview-heading">Practical help for financial pressure</h2>
          </div>
          <p>At Oakdene House Foundation, we understand that financial stress and mental health are often deeply connected. Money worries can affect sleep, relationships, confidence, physical health, and recovery from addiction or gambling harm. For many people, financial pressure becomes one of the biggest barriers to stability and wellbeing.</p>

          <p>Our Financial Counselling Service provides free, confidential support from a qualified Financial Counsellor for individuals and families experiencing financial hardship, debt stress, gambling-related financial impacts, housing insecurity, or difficulty managing day-to-day costs.</p>

          <p>This is not a budgeting app or a quick advice session. Financial counselling is a professional support service focused on helping people understand their situation, reduce pressure, and regain a sense of control.</p>

          <h3 class="section-subhead">What a Financial Counsellor can help with</h3>

          <ul class="offer-list">
            <li>Debt and overdue bills</li>
            <li>Gambling-related financial harm</li>
            <li>Rent or mortgage stress</li>
            <li>Utility disconnections and payment plans</li>
            <li>Credit cards, personal loans, and buy-now-pay-later debt</li>
            <li>Centrelink and financial hardship issues</li>
            <li>Negotiating with creditors</li>
            <li>Financial stress linked to addiction or mental health challenges</li>
            <li>Creating practical financial plans</li>
            <li>Referrals to emergency relief and community supports</li>
          </ul>

          <div class="access-note">
            <h3>How to access</h3>
            <p>You can access financial counselling through a referral form, by phone, or by email. No prior referral from another service is required.</p>
            <div class="btn-group">
              <a href="/services/referral/" class="btn btn--primary">Submit a Request</a><!-- TODO: Replace with live Jotform URL -->
              <a href="/contact/" class="btn btn--secondary">Contact Us</a>
            </div>
          </div>
        </div>
        <div>
          <InfoTable rows={serviceRows} caption="Service details" />
        </div>
      </div>
    </div>
  </section>

  <!-- OUR APPROACH + FCA ACCREDITATION -->
  <section class="section section--tint" aria-labelledby="approach-heading">
    <div class="container">
      <div class="what-inner">
        <div class="section-heading">
          <p class="section-heading__eyebrow">A Practical and Compassionate Approach</p>
          <h2 id="approach-heading">Support without lectures or judgement</h2>
        </div>

        <div class="approach-content">
          <p>Financial counselling at Oakdene is delivered in a respectful, non-judgemental way. Many people avoid seeking help because of shame, embarrassment, or fear about their financial situation. Our role is not to lecture or criticise. It is to help reduce pressure, improve understanding, and support practical next steps.</p>

          <p>Where needed, financial counselling can also work alongside our counselling, recovery, and support programs to provide more holistic care. This is particularly important for people affected by gambling harm, addiction, relationship breakdown, or periods of significant emotional distress.</p>

          <h3 class="section-subhead">Qualified and Professional Support</h3>

          <p>All financial counselling services at Oakdene House Foundation are delivered by a qualified Financial Counsellor with experience supporting people facing complex financial and personal challenges. Our Financial Counsellor is professionally registered and operates in line with Australian financial counselling standards and ethical requirements.</p>

          <p>Financial counsellors work independently and in the best interests of the client, providing free, confidential, and non-judgemental support. Financial counselling in Australia is supported nationally by Financial Counselling Australia (FCA), the peak body representing the profession.</p>

          <!-- TODO: FCA logo placement here — Simon to provide logo file. Should sit visually anchored near this paragraph. -->
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABand
    heading="Need help with finances?"
    subheading="Get in touch to arrange a session. We will start from where you are."
    primaryBtn={{ text: 'Submit a Request', href: '/services/referral/' }}
    secondaryBtn={{ text: 'Contact Us', href: '/contact/' }}
    dark={true}
  />

</BaseLayout>

<style>
  .fc-hero {
    position: relative;
    min-height: 380px;
    background-image: url('/images/generic/bandw-business-man_distress.jpg');
    background-size: cover;
    background-position: center top;
    display: flex;
    align-items: flex-end;
  }

  .fc-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,62,81,0.5) 0%, rgba(0,62,81,0.92) 100%);
  }

  .fc-hero__content {
    position: relative;
    z-index: 1;
    padding-block: 56px;
  }

  .fc-hero__content h1 { color: var(--color-white); margin-bottom: 10px; }

  .fc-hero__lead {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.88);
    margin-bottom: 0;
    max-width: 520px;
  }

  .section-subhead {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    margin: 24px 0 14px;
  }

  .offer-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 0;
    list-style: none;
    margin-bottom: 28px;
  }

  .offer-list li {
    padding-left: 24px;
    position: relative;
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.55;
  }

  .offer-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-primary);
  }

  .access-note {
    background-color: var(--color-tint);
    border-radius: var(--radius-card);
    border: 1px solid var(--color-secondary);
    padding: 24px 28px;
  }

  .access-note h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 10px;
  }

  .access-note p {
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  /* Approach section */
  .what-inner {
    max-width: 860px;
    margin-inline: auto;
  }

  .approach-content p {
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.6;
    margin-bottom: 18px;
  }

  .approach-content p:last-of-type {
    margin-bottom: 0;
  }
</style>
