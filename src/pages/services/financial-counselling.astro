---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InfoTable from '../../components/InfoTable.astro';
import CTABand from '../../components/CTABand.astro';

const serviceRows = [
  { label: 'Cost', value: 'Free' },
  { label: 'Access', value: 'By referral or contact us' },
  { label: 'Location', value: 'Oakdene Centre, 29 Vine Street, Fairfield' },
  { label: 'Phone', value: '<a href="tel:0287170999">(02) 8717 0999</a>' },
  { label: 'Email', value: '<a href="mailto:admin@oakdenehouse.org.au">admin@oakdenehouse.org.au</a>' },
];

const helpWith = [
  'Understanding your financial options',
  'Managing debt',
  'Dealing with bills and expenses',
  'Planning for the future',
];
---

<BaseLayout
  title="Financial Counselling — Oakdene House Foundation"
  description="Free financial counselling at Oakdene House for people experiencing hardship. Help with debt, bills, expenses and financial planning in Fairfield, Western Sydney."
  ogImage="/images/generic/bandw-business-man_distress.jpg"
>

  <!-- HERO -->
  <section class="fc-hero" aria-label="Financial Counselling">
    <div class="fc-hero__overlay" aria-hidden="true"></div>
    <div class="container fc-hero__content">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <a href="/services/">Services</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span aria-current="page">Financial Counselling</span>
      </nav>
      <h1>Financial Counselling</h1>
      <p class="fc-hero__lead">Free guidance for people experiencing financial hardship.</p>
    </div>
  </section>

  <!-- OVERVIEW -->
  <section class="section" aria-labelledby="fc-overview-heading">
    <div class="container">
      <div class="split">
        <div>
          <div class="section-heading">
            <p class="section-heading__eyebrow">The Service</p>
            <h2 id="fc-overview-heading">Practical help for financial pressure</h2>
          </div>
          <p>Financial difficulties can affect every part of life. Oakdene's financial counselling service offers free, practical guidance to help people understand their options and take steps toward greater stability.</p>
          <p>Whether you are dealing with debt, falling behind on bills, or feeling overwhelmed by financial stress — we are here to help you work through it.</p>

          <h3 class="section-subhead">What we help with</h3>
          <ul class="help-list">
            {helpWith.map(item => <li>{item}</li>)}
          </ul>

          <div class="access-note">
            <h3>How to access</h3>
            <p>You can access financial counselling through a referral form, by phone, or by email. No prior referral from another service is required.</p>
            <div class="btn-group">
              <a href="/forms/" class="btn btn--primary">Submit a Request</a><!-- TODO: Replace with live Jotform URL -->
              <a href="/contact/" class="btn btn--secondary">Contact Us</a>
            </div>
          </div>
        </div>
        <div>
          <InfoTable rows={serviceRows} caption="Service details" />
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT FINANCIAL COUNSELLING IS -->
  <section class="section section--tint" aria-labelledby="what-heading">
    <div class="container">
      <div class="what-inner">
        <div class="section-heading section-heading--center">
          <p class="section-heading__eyebrow">What Is Financial Counselling?</p>
          <h2 id="what-heading">Not a loan — real guidance</h2>
          <p class="section-heading__lead">Financial counselling is a professional service that helps people in financial difficulty understand their rights and options. It is different from financial planning or advice.</p>
        </div>
        <div class="what-grid">
          <div class="what-item">
            <div class="what-item__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 8 16 12 12 16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
            </div>
            <h3>Know your rights</h3>
            <p>Understand what creditors can and cannot do, and how to protect yourself from unfair practices.</p>
          </div>
          <div class="what-item">
            <div class="what-item__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <h3>Manage debt</h3>
            <p>Get practical strategies to negotiate with creditors, manage repayments and reduce financial stress.</p>
          </div>
          <div class="what-item">
            <div class="what-item__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
            <h3>Plan ahead</h3>
            <p>Work toward a budget and financial plan that reflects your real situation and goals.</p>
          </div>
        </div>

        <div class="free-note">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <p>This service is completely <strong>free of charge</strong>. Financial counselling at Oakdene is available to anyone experiencing hardship — you do not need to be an existing client.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABand
    heading="Need help with finances?"
    subheading="Get in touch to arrange a session. We will start from where you are."
    primaryBtn={{ text: 'Submit a Request', href: '/forms/' }}
    secondaryBtn={{ text: 'Contact Us', href: '/contact/' }}
    dark={true}
  />

</BaseLayout>

<style>
  .fc-hero {
    position: relative;
    min-height: 380px;
    background-image: url('/images/generic/bandw-business-man_distress.jpg');
    background-size: cover;
    background-position: center top;
    display: flex;
    align-items: flex-end;
  }

  .fc-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,62,81,0.5) 0%, rgba(0,62,81,0.92) 100%);
  }

  .fc-hero__content {
    position: relative;
    z-index: 1;
    padding-block: 56px;
  }

  .fc-hero__content h1 { color: var(--color-white); margin-bottom: 10px; }

  .fc-hero__lead {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.88);
    margin-bottom: 0;
    max-width: 520px;
  }

  .section-subhead {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    margin: 24px 0 14px;
  }

  .help-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 0;
    list-style: none;
    margin-bottom: 28px;
  }

  .help-list li {
    padding-left: 24px;
    position: relative;
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.55;
  }

  .help-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-primary);
  }

  .access-note {
    background-color: var(--color-tint);
    border-radius: var(--radius-card);
    border: 1px solid var(--color-secondary);
    padding: 24px 28px;
  }

  .access-note h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 10px;
  }

  .access-note p {
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  /* What is */
  .what-inner {
    max-width: 860px;
    margin-inline: auto;
  }

  .what-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 32px;
  }

  .what-item {
    background-color: var(--color-white);
    border-radius: var(--radius-card);
    padding: 24px 20px;
    border: 1px solid var(--color-secondary);
  }

  .what-item__icon {
    color: var(--color-primary);
    margin-bottom: 12px;
  }

  .what-item h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 8px;
  }

  .what-item p {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: 0;
  }

  .free-note {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    background-color: var(--color-white);
    border-radius: var(--radius-card);
    border: 1px solid var(--color-secondary);
    border-left: 3px solid var(--color-primary);
    padding: 18px 22px;
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.6;
  }

  .free-note svg {
    color: var(--color-primary);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .free-note p {
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .what-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
