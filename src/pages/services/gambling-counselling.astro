---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABand from '../../components/CTABand.astro';
---

<BaseLayout
  title="Gambling Counselling — Oakdene House Foundation"
  description="Free, confidential gambling counselling at Oakdene House, provided by Catholic Care. By appointment. Fairfield, Western Sydney."
  ogImage="/images/generic/bandw-distressed-woman.jpeg"
>

  <!-- HERO -->
  <section class="gc-hero" aria-label="Gambling Counselling">
    <div class="gc-hero__overlay" aria-hidden="true"></div>
    <div class="container gc-hero__content">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <a href="/services/">Services</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span aria-current="page">Gambling Counselling</span>
      </nav>
      <h1>Gambling Counselling</h1>
      <p class="gc-hero__lead">Free, confidential one-on-one counselling for people affected by gambling.</p>
    </div>
  </section>

  <!-- OVERVIEW -->
  <section class="section" aria-labelledby="gc-overview-heading">
    <div class="container">
      <div class="split">
        <div>
          <div class="section-heading">
            <p class="section-heading__eyebrow">About this service</p>
            <h2 id="gc-overview-heading">Support without judgment</h2>
          </div>
          <p>Oakdene offers free, confidential one-on-one gambling counselling delivered by our team. Our counsellors are specially trained and experienced in addiction counselling, supporting people affected by gambling and helping them work through their challenges with dignity and respect.</p>
          <p>Counselling is delivered by appointment on a one-to-one basis. All conversations are confidential and non-judgmental.</p>

          <div class="service-facts">
            <div class="service-fact">
              <span class="service-fact__label">Cost</span>
              <span class="service-fact__value">Free</span>
            </div>
            <div class="service-fact">
              <span class="service-fact__label">Access</span>
              <span class="service-fact__value">By appointment</span>
            </div>
            <div class="service-fact">
              <span class="service-fact__label">Confidential</span>
              <span class="service-fact__value">Yes — all sessions are private</span>
            </div>
          </div>

          <div class="contact-line">
            <a href="tel:0287170999" class="contact-phone">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.09 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 5.98 5.98l1.28-1.28a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.02z"/></svg>
              (02) 8717 0999
            </a>
            <a href="mailto:admin@oakdenehouse.org.au" class="contact-email">admin@oakdenehouse.org.au</a>
          </div>
        </div>
        <div class="gc-right">
          <div class="gc-image">
            <img src="/images/generic/bandw-man-with-glasses-eyes-closed.jpeg" alt="Person finding support through counselling" loading="lazy" />
          </div>
          <div class="helpline-box">
            <div class="helpline-box__icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <div>
              <p class="helpline-box__heading">24-hour support line</p>
              <p>If you need to talk right now, the Gambling Help Line is free and available 24 hours a day.</p>
              <a href="tel:1800858858" class="helpline-number">1800 858 858</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT WE ADDRESS -->
  <section class="section section--tint" aria-labelledby="address-heading">
    <div class="container">
      <div class="address-inner">
        <div class="section-heading section-heading--center">
          <p class="section-heading__eyebrow">How We Help</p>
          <h2 id="address-heading">Understanding the impact of gambling</h2>
          <p class="section-heading__lead">Gambling can affect every part of a person's life. Our counsellors work with you across all of it.</p>
        </div>
        <div class="impact-grid">
          <div class="impact-item">
            <h3>Financial pressure</h3>
            <p>Debt, loss of income, and financial instability are common consequences. Counselling helps you understand your options and plan ahead. Our <a href="/services/financial-counselling/">Financial Counselling</a> service can also help with gambling-related financial harm, debt, and money stress.</p>
          </div>
          <div class="impact-item">
            <h3>Relationships</h3>
            <p>Gambling can strain family and personal relationships. We support honest conversations and rebuilding trust.</p>
          </div>
          <div class="impact-item">
            <h3>Mental wellbeing</h3>
            <p>Shame, anxiety and depression often accompany problem gambling. Counselling provides a space to process these experiences.</p>
          </div>
          <div class="impact-item">
            <h3>Recovery planning</h3>
            <p>We help you identify goals, build strategies and develop a personalised path forward.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABand
    heading="Take the first step"
    subheading="You do not have to figure this out alone. Reach out and we will arrange an appointment."
    primaryBtn={{ text: 'Counselling Referral', href: '/services/referral/' }}
    secondaryBtn={{ text: 'Contact Us', href: '/contact/' }}
    dark={true}
  />

</BaseLayout>

<style>
  .gc-hero {
    position: relative;
    min-height: 380px;
    background-image: url('/images/generic/bandw-distressed-woman.jpeg');
    background-size: cover;
    background-position: center top;
    display: flex;
    align-items: flex-end;
  }

  .gc-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,62,81,0.45) 0%, rgba(0,62,81,0.9) 100%);
  }

  .gc-hero__content {
    position: relative;
    z-index: 1;
    padding-block: 56px;
  }

  .gc-hero__content h1 { color: var(--color-white); margin-bottom: 10px; }

  .gc-hero__lead {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.88);
    margin-bottom: 0;
    max-width: 520px;
  }

  .service-facts {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 28px 0;
    padding: 20px 24px;
    background-color: var(--color-tint);
    border-radius: var(--radius-card);
    border: 1px solid var(--color-secondary);
  }

  .service-fact {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 8px;
    font-size: 0.9375rem;
  }

  .service-fact__label {
    font-weight: 600;
    color: var(--color-primary);
  }

  .service-fact__value {
    color: var(--color-text);
  }

  .contact-line {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .contact-phone {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
  }

  .contact-phone:hover { text-decoration: underline; }

  .contact-email {
    font-size: 0.9375rem;
    color: var(--color-primary);
    font-weight: 500;
    text-decoration: none;
  }

  .contact-email:hover { text-decoration: underline; }

  .gc-right {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .gc-image {
    border-radius: var(--radius-card);
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .gc-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .helpline-box {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    background-color: var(--color-tint);
    border-radius: var(--radius-card);
    border: 1px solid var(--color-secondary);
    border-left: 3px solid var(--color-primary);
    padding: 20px 24px;
  }

  .helpline-box__icon {
    color: var(--color-primary);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .helpline-box__heading {
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    margin-bottom: 6px;
  }

  .helpline-box p:nth-child(2) {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: 10px;
    line-height: 1.5;
  }

  .helpline-number {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
    display: block;
  }

  .helpline-number:hover { text-decoration: underline; }

  /* Impact grid */
  .address-inner {
    max-width: 860px;
    margin-inline: auto;
  }

  .impact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .impact-item {
    background-color: var(--color-white);
    border-radius: var(--radius-card);
    padding: 24px;
    border: 1px solid var(--color-secondary);
  }

  .impact-item h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 10px;
  }

  .impact-item p {
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: 0;
  }

  @media (max-width: 600px) {
    .impact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
