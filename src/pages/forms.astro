---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/CTABand.astro';

const forms = [
  {
    title: 'General Enquiry',
    description: 'Got a question or want to know more? Send us a general enquiry.',
    icon: 'mail',
  },
  {
    title: 'Referral Form',
    description: 'Referring yourself or someone else for support? Complete our referral form.',
    icon: 'share',
  },
  {
    title: 'Volunteer Application',
    description: 'Interested in volunteering with Oakdene? Tell us about yourself.',
    icon: 'heart',
  },
  {
    title: 'Program Interest',
    description: 'Want to join one of our community programs? Express your interest.',
    icon: 'people',
  },
  {
    title: 'Donation or Partnership Enquiry',
    description: 'Want to support our work or explore a partnership?',
    icon: 'star',
  },
];

const nextSteps = [
  { heading: 'Choose Form', body: 'Select the form that best matches your enquiry.' },
  { heading: 'Submit Details', body: 'Complete and submit the form online. It only takes a few minutes.' },
  { heading: 'We Review', body: 'Our team will review your submission and determine the best next step.' },
  { heading: 'Follow-up', body: 'Someone from Oakdene will be in touch within 2 business days.' },
];
---

<BaseLayout
  title="Forms — Oakdene House Foundation"
  description="Submit a general enquiry, referral, volunteer application or program interest form online. Oakdene House Foundation will follow up within 2 business days."
>

  <!-- HERO — dark teal -->
  <section class="forms-hero" aria-label="Forms and enquiries">
    <div class="container forms-hero__content">
      <h1>Forms and online enquiries</h1>
      <p class="forms-hero__lead">Choose the right form below and Oakdene will follow up with the next step.</p>
    </div>
  </section>

  <!-- FORM CARDS -->
  <section class="section" aria-labelledby="forms-heading">
    <div class="container">
      <div class="section-heading section-heading--center">
        <p class="section-heading__eyebrow">Choose a Form</p>
        <h2 id="forms-heading">How can we help?</h2>
      </div>
      <div class="forms-grid">
        {forms.map(f => (
          <div class="form-card">
            <div class="form-card__icon" aria-hidden="true">
              {f.icon === 'mail' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              )}
              {f.icon === 'share' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
              )}
              {f.icon === 'heart' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              )}
              {f.icon === 'people' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              )}
              {f.icon === 'star' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              )}
            </div>
            <h3 class="form-card__title">{f.title}</h3>
            <p class="form-card__desc">{f.description}</p>
            <a href="#form-placeholder" class="btn btn--primary form-card__btn"><!-- TODO: Replace with live Jotform URL -->
              Open Form
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT HAPPENS NEXT -->
  <section class="section section--tint" aria-labelledby="next-heading">
    <div class="container">
      <div class="section-heading section-heading--center">
        <p class="section-heading__eyebrow">After You Submit</p>
        <h2 id="next-heading">What happens next</h2>
      </div>
      <div class="next-steps">
        {nextSteps.map((step, i) => (
          <div class="next-step">
            <div class="next-step__number" aria-hidden="true">{String(i + 1).padStart(2, '0')}</div>
            <h3 class="next-step__heading">{step.heading}</h3>
            <p class="next-step__body">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PREFER TO TALK -->
  <section class="section" aria-labelledby="talk-heading">
    <div class="container">
      <div class="talk-inner">
        <div class="section-heading">
          <p class="section-heading__eyebrow">Prefer to Talk?</p>
          <h2 id="talk-heading">We are here to help directly</h2>
        </div>
        <p>If you would rather speak to someone directly, you can call or email us. Our team is available Monday to Friday during business hours.</p>
        <div class="talk-contacts">
          <a href="tel:0287170999" class="talk-phone">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.09 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 5.98 5.98l1.28-1.28a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.02z"/></svg>
            (02) 8717 0999
          </a>
          <a href="mailto:admin@oakdenehouse.org.au" class="talk-email">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            admin@oakdenehouse.org.au
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABand
    heading="Not sure which form to use?"
    primaryBtn={{ text: 'Contact Us', href: '/contact/' }}
    secondaryBtn={{ text: 'Back to Home', href: '/' }}
    dark={true}
  />

</BaseLayout>

<style>
  .forms-hero {
    background-color: var(--color-primary);
    padding-block: 72px 64px;
  }

  .forms-hero__content {
    max-width: 640px;
  }

  .forms-hero__content h1 {
    color: var(--color-white);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 14px;
  }

  .forms-hero__lead {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.88);
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* Form cards */
  .forms-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .form-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-secondary);
    border-radius: var(--radius-card);
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .form-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card);
  }

  .form-card__icon {
    color: var(--color-primary);
    margin-bottom: 16px;
  }

  .form-card__title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .form-card__desc {
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: 20px;
    flex: 1;
  }

  .form-card__btn {
    align-self: flex-start;
  }

  /* Next steps */
  .next-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }

  .next-step {
    background-color: var(--color-white);
    border-radius: var(--radius-card);
    border: 1px solid var(--color-secondary);
    padding: 28px 22px;
    text-align: center;
  }

  .next-step__number {
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-secondary);
    line-height: 1;
    margin-bottom: 14px;
  }

  .next-step__heading {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 8px;
  }

  .next-step__body {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* Prefer to talk */
  .talk-inner {
    max-width: 560px;
  }

  .talk-contacts {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 24px;
  }

  .talk-phone {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
  }

  .talk-phone:hover { text-decoration: underline; }

  .talk-email {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
  }

  .talk-email:hover { text-decoration: underline; }

  @media (max-width: 900px) {
    .forms-grid { grid-template-columns: repeat(2, 1fr); }
    .next-steps { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .forms-grid { grid-template-columns: 1fr; }
    .next-steps { grid-template-columns: 1fr; }
  }
</style>
