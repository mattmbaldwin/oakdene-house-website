---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — Oakdene House Foundation"
  description="The page you were looking for could not be found."
>

  <section class="not-found" aria-label="Page not found">
    <div class="container not-found__inner">
      <div class="not-found__icon" aria-hidden="true">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <p class="not-found__code">404</p>
      <h1>Page not found</h1>
      <p class="not-found__sub">Sorry, we could not find the page you were looking for.</p>
      <p class="not-found__body">It may have been moved or the link may be out of date. Try one of the links below or return to the home page.</p>

      <div class="not-found__links">
        <a href="/" class="btn btn--primary">Back to Home</a>
        <a href="/services/" class="btn btn--secondary">Services</a>
        <a href="/contact/" class="btn btn--secondary">Contact</a>
        <a href="/need-help-now/" class="btn btn--secondary">Need Help Now</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .not-found {
    min-height: calc(100vh - 200px);
    display: flex;
    align-items: center;
    padding-block: 80px;
    background-color: var(--color-tint);
  }

  .not-found__inner {
    max-width: 560px;
    text-align: center;
  }

  .not-found__icon {
    color: var(--color-secondary);
    margin-bottom: 16px;
  }

  .not-found__code {
    font-size: 5rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
    margin-bottom: 4px;
    opacity: 0.15;
  }

  .not-found h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: var(--color-primary);
    margin-bottom: 12px;
  }

  .not-found__sub {
    font-size: 1.125rem;
    color: var(--color-text);
    margin-bottom: 12px;
    line-height: 1.6;
  }

  .not-found__body {
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.7;
    margin-bottom: 36px;
  }

  .not-found__links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }

  @media (max-width: 480px) {
    .not-found__links {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
