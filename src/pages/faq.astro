---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="FAQ — Oakdene House Foundation"
  description="Frequently asked questions about Oakdene House Foundation's services, programs, volunteering, donations, and more."
>

  <!-- HERO -->
  <section class="faq-hero" aria-label="FAQ">
    <div class="container faq-hero__content">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span aria-current="page">FAQ</span>
      </nav>
      <h1>Frequently asked questions</h1>
      <p class="faq-hero__subtitle">Quick answers to the questions we hear most often. If you can't find what you're looking for, reach out — we're here to help.</p>
    </div>
  </section>

  <!-- MAIN CONTENT -->
  <section class="section" aria-label="FAQ content">
    <div class="container">
      <div class="faq-wrap">

        <!-- JUMPLINKS -->
        <nav class="faq-jumplinks" aria-label="Jump to FAQ category">
          <a href="#cat-a">A. Getting support</a>
          <a href="#cat-b">B. Counselling and clinical services</a>
          <a href="#cat-c">C. Community programs</a>
          <a href="#cat-d">D. Volunteering</a>
          <a href="#cat-e">E. Donations and partnerships</a>
          <a href="#cat-f">F. About Oakdene</a>
          <a href="#cat-g">G. Privacy and information</a>
        </nav>

        <!-- Search filter could be added here in future - likely client-side JS filtering question titles and answers. Currently the chatbot will fulfil the search role. -->

        <!-- ============================================================
             CATEGORY A — Getting support
             ============================================================ -->
        <div class="faq-category" id="cat-a">
          <h2 class="faq-cat-heading">A. Getting support</h2>
          <div class="faq-group">

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-a-1-content" id="faq-a-1-btn">
                <span class="faq-question">Who can access Oakdene's services?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-a-1-content" role="region" aria-labelledby="faq-a-1-btn">
                <div class="faq-content-inner">
                  <p>Anyone facing challenges with addiction, hardship, homelessness, or other life pressures can contact us. You don't need to meet specific criteria — if you're going through a difficult time and want support, we're here.</p>
                </div>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-a-2-content" id="faq-a-2-btn">
                <span class="faq-question">Do I need a referral?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-a-2-content" role="region" aria-labelledby="faq-a-2-btn">
                <div class="faq-content-inner">
                  <p>Not always. Some services (like the Kitchen, Laundrette, and Boutique) are drop-in and don't need a referral. For counselling and the Life Choices program, a referral helps us understand your situation, but you can also refer yourself directly.</p>
                </div>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-a-3-content" id="faq-a-3-btn">
                <span class="faq-question">How do I make a referral?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-a-3-content" role="region" aria-labelledby="faq-a-3-btn">
                <div class="faq-content-inner">
                  <p>Use our online <a href="/services/referral/">referral form</a> or call <a href="tel:+61287170999">(02) 8717 0999</a>. Referrals can come from the person seeking support, a family member, or a professional (GP, case worker, corrections officer, etc.).</p>
                </div>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-a-4-content" id="faq-a-4-btn">
                <span class="faq-question">How long does it take to hear back after I contact you?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-a-4-content" role="region" aria-labelledby="faq-a-4-btn">
                <div class="faq-content-inner">
                  <p>We aim to respond to all enquiries within 2 business days. If you need help urgently, please call us directly on <a href="tel:+61287170999">(02) 8717 0999</a>, or see our <a href="/need-help-now/">Need Help Now page</a> for 24/7 crisis lines.</p>
                </div>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-a-5-content" id="faq-a-5-btn">
                <span class="faq-question">Is everything confidential?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-a-5-content" role="region" aria-labelledby="faq-a-5-btn">
                <div class="faq-content-inner">
                  <p>Yes. What you share with an Oakdene counsellor or staff member is confidential, with a few important exceptions we're required by law to disclose (serious risk of harm to yourself or others, subpoena, or child protection concerns). Your counsellor will explain this at your first session.</p>
                </div>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-a-6-content" id="faq-a-6-btn">
                <span class="faq-question">Is there a cost?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-a-6-content" role="region" aria-labelledby="faq-a-6-btn">
                <div class="faq-content-inner">
                  <p>Most Oakdene services are free. Some community services (like the Ladies Boutique) ask for a gold coin donation. We'll always be upfront about any cost before you start.</p>
                </div>
              </div>
            </div>

          </div>
        </div>

        <!-- ============================================================
             CATEGORY B — Counselling and clinical services
             ============================================================ -->
        <div class="faq-category" id="cat-b">
          <h2 class="faq-cat-heading">B. Counselling and clinical services</h2>
          <div class="faq-group">

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-b-1-content" id="faq-b-1-btn">
                <span class="faq-question">What kind of counselling do you offer?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-b-1-content" role="region" aria-labelledby="faq-b-1-btn">
                <div class="faq-content-inner">
                  <p>We offer individual counselling, gambling counselling (via Catholic Care), and group programs. Our counsellors have specialist training in addiction, recovery, trauma, and mental health.</p>
                </div>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-b-2-content" id="faq-b-2-btn">
                <span class="faq-question">How long are counselling sessions?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-b-2-content" role="region" aria-labelledby="faq-b-2-btn">
                <div class="faq-content-inner">
                  <p>Typically 50–60 minutes. Your counsellor will talk with you about frequency — weekly, fortnightly, or as needed.</p>
                </div>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-b-3-content" id="faq-b-3-btn">
                <span class="faq-question">What is the Life Choices Program?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-b-3-content" role="region" aria-labelledby="faq-b-3-btn">
                <div class="faq-content-inner">
                  <p>A 6-week group program focused on recovery, life skills, and peer connection. See the <a href="/services/life-choices-program/">Life Choices page</a> for details.</p>
                </div>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-b-4-content" id="faq-b-4-btn">
                <span class="faq-question">What is the Outpatients Program?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-b-4-content" role="region" aria-labelledby="faq-b-4-btn">
                <div class="faq-content-inner">
                  <p>A structured rehabilitation program combining counselling, group sessions, 12-step support, and peer mentoring. See the <a href="/services/outpatients-program/">Outpatients Program page</a> for details.</p>
                </div>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-b-5-content" id="faq-b-5-btn">
                <span class="faq-question">Do you offer support in languages other than English?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-b-5-content" role="region" aria-labelledby="faq-b-5-btn">
                <div class="faq-content-inner">
                  <p>Yes. Several of our staff speak languages other than English, and we can arrange an interpreter if you let us know when you contact us. Our AA / GA meetings include Spanish-speaking sessions.</p>
                </div>
              </div>
            </div>

          </div>
        </div>

        <!-- ============================================================
             CATEGORY C — Community programs
             ============================================================ -->
        <div class="faq-category" id="cat-c">
          <h2 class="faq-cat-heading">C. Community programs</h2>
          <div class="faq-group">

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-c-1-content" id="faq-c-1-btn">
                <span class="faq-question">When is the Kitchen open?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-c-1-content" role="region" aria-labelledby="faq-c-1-btn">
                <div class="faq-content-inner">
                  <p>Tuesday, Wednesday, and Thursday, 12pm–2pm. Free nutritious meals are available to eligible community members.</p>
                </div>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-c-2-content" id="faq-c-2-btn">
                <span class="faq-question">When is the Laundrette open?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-c-2-content" role="region" aria-labelledby="faq-c-2-btn">
                <div class="faq-content-inner">
                  <p>Tuesday to Thursday, 12pm–2:30pm (last entry 1pm). Washing, drying, and detergent are provided free.</p>
                </div>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-c-3-content" id="faq-c-3-btn">
                <span class="faq-question">Can I get food to take home?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-c-3-content" role="region" aria-labelledby="faq-c-3-btn">
                <div class="faq-content-inner">
                  <p>Yes. Staple Food Packs are available every Friday, 12pm–2pm.</p>
                </div>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-c-4-content" id="faq-c-4-btn">
                <span class="faq-question">What is the Ladies Boutique?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-c-4-content" role="region" aria-labelledby="faq-c-4-btn">
                <div class="faq-content-inner">
                  <p>A warm, private space offering quality clothing and salon services for women, by appointment. No woman is turned away due to financial difficulty.</p>
                </div>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-c-5-content" id="faq-c-5-btn">
                <span class="faq-question">Do I need to book?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-c-5-content" role="region" aria-labelledby="faq-c-5-btn">
                <div class="faq-content-inner">
                  <p>Most drop-in community services don't need a booking during open hours. Ladies Boutique and counselling are by appointment.</p>
                </div>
              </div>
            </div>

          </div>
        </div>

        <!-- ============================================================
             CATEGORY D — Volunteering
             ============================================================ -->
        <div class="faq-category" id="cat-d">
          <h2 class="faq-cat-heading">D. Volunteering</h2>
          <div class="faq-group">

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-d-1-content" id="faq-d-1-btn">
                <span class="faq-question">How do I apply to volunteer?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-d-1-content" role="region" aria-labelledby="faq-d-1-btn">
                <div class="faq-content-inner">
                  <p>Submit our <a href="/community-programs/volunteering/">volunteer application form</a>. We'll get back to you within 2 business days to arrange a brief conversation.</p>
                </div>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-d-2-content" id="faq-d-2-btn">
                <span class="faq-question">Do I need experience?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-d-2-content" role="region" aria-labelledby="faq-d-2-btn">
                <div class="faq-content-inner">
                  <p>No. We value willingness, reliability, and a caring approach more than prior experience. We'll support you in your role.</p>
                </div>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-d-3-content" id="faq-d-3-btn">
                <span class="faq-question">Can my workplace / team volunteer together?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-d-3-content" role="region" aria-labelledby="faq-d-3-btn">
                <div class="faq-content-inner">
                  <p>Yes — we offer structured corporate volunteering days. See the <a href="/community-programs/volunteering/corporate-volunteering/">Corporate Volunteering page</a> or get in touch.</p>
                </div>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-d-4-content" id="faq-d-4-btn">
                <span class="faq-question">Will I need a police check?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-d-4-content" role="region" aria-labelledby="faq-d-4-btn">
                <div class="faq-content-inner">
                  <p>For some volunteer roles (especially those involving clients or children), yes. We'll discuss this during your application.</p>
                </div>
              </div>
            </div>

          </div>
        </div>

        <!-- ============================================================
             CATEGORY E — Donations and partnerships
             ============================================================ -->
        <div class="faq-category" id="cat-e">
          <h2 class="faq-cat-heading">E. Donations and partnerships</h2>
          <div class="faq-group">

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-e-1-content" id="faq-e-1-btn">
                <span class="faq-question">Is my donation tax-deductible?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-e-1-content" role="region" aria-labelledby="faq-e-1-btn">
                <div class="faq-content-inner">
                  <p>Yes — donations of $2 or more are tax-deductible, subject to our DGR status.</p>
                </div>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-e-2-content" id="faq-e-2-btn">
                <span class="faq-question">Can I set up a regular monthly donation?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-e-2-content" role="region" aria-labelledby="faq-e-2-btn">
                <div class="faq-content-inner">
                  <p>Yes — see our <a href="/support-us/">Support Us page</a> for one-off or monthly giving options.</p>
                </div>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-e-3-content" id="faq-e-3-btn">
                <span class="faq-question">How do I cancel a monthly donation?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-e-3-content" role="region" aria-labelledby="faq-e-3-btn">
                <div class="faq-content-inner">
                  <p>Email <a href="mailto:admin@oakdenehouse.org.au">admin@oakdenehouse.org.au</a> or use the cancellation link in your donation email.</p>
                </div>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-e-4-content" id="faq-e-4-btn">
                <span class="faq-question">How are donations used?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-e-4-content" role="region" aria-labelledby="faq-e-4-btn">
                <div class="faq-content-inner">
                  <p>Oakdene operates lean. Over 90% of donations go directly to service delivery.</p>
                </div>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-e-5-content" id="faq-e-5-btn">
                <span class="faq-question">My company wants to partner with Oakdene. Who do I contact?</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-content" id="faq-e-5-content" role="region" aria-labelledby="faq-e-5-btn">
                <div class="faq-content-inner">
                  <p>Email <a href="mailto:admin@oakdenehouse.org.au">admin@oakdenehouse.org.au</a> or use the <a href="/contact/">contact form</a> and select "Partnership or organisation enquiry".</p>
                </div>
              </div>
            </div>

          </div>
        </div>

        <!-- ============================================================
             CATEGORY F — About Oakdene
             ============================================================ -->
        <div class="faq-category" id="cat-f">
          <h2 class="faq-cat-heading">F. About Oakdene</h2>
          <div class="faq-group">

            <div class="faq-item">
              <button class="faq-btn" aria-expanded="false" aria-controls="faq-f-1-content" id="faq-f-1-btn">
                <span class="faq-question">Where are you located?</span>
