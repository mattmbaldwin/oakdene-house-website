<style>
  /* ---- Hero ---- */
  .faq-hero {
    background-color: var(--color-primary);
    padding-block: 52px 44px;
  }

  .faq-hero h1 {
    color: var(--color-white);
    margin-bottom: 14px;
  }

  .faq-hero__subtitle {
    color: rgba(255, 255, 255, 0.82);
    font-size: 1.0625rem;
    line-height: 1.6;
    max-width: 600px;
    margin-bottom: 0;
  }

  /* ---- Page wrapper ---- */
  .faq-wrap {
    max-width: 860px;
    margin-inline: auto;
  }

  /* ---- Jumplinks ---- */
  .faq-jumplinks {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 40px;
  }

  .faq-jumplinks a {
    display: inline-flex;
    align-items: center;
    padding: 6px 14px;
    border: 1.5px solid var(--color-primary);
    border-radius: 20px;
    color: var(--color-primary);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color var(--transition), color var(--transition);
  }

  .faq-jumplinks a:hover {
    background-color: var(--color-primary);
    color: var(--color-white);
  }

  /* ---- Category blocks ---- */
  .faq-category {
    margin-bottom: 52px;
    /* scroll-margin-top on the anchor target (this div), not the child h2 */
    scroll-margin-top: 100px;
  }

  .faq-cat-heading {
    font-size: 1.1875rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--color-secondary);
  }

  /* ---- Accordion group container ---- */
  .faq-group {
    border: 1px solid var(--color-secondary);
    border-radius: var(--radius-card);
    overflow: hidden;
  }

  /* ---- Individual accordion item ---- */
  .faq-item {
    border-bottom: 1px solid var(--color-secondary);
  }

  .faq-item:last-child {
    border-bottom: none;
  }

  /* ---- Question button ---- */
  .faq-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 24px;
    background-color: var(--color-white);
    border: none;
    cursor: pointer;
    text-align: left;
    min-height: 64px;
    transition: background-color var(--transition);
  }

  .faq-btn:hover {
    background-color: var(--color-tint);
  }

  .faq-btn:focus-visible {
    outline: 3px solid var(--color-primary);
    outline-offset: -3px;
  }

  .faq-item.is-open .faq-btn {
    background-color: var(--color-tint);
  }

  /* ---- Question text ---- */
  .faq-question {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.45;
  }

  .faq-item.is-open .faq-question {
    color: var(--color-primary);
  }

  /* ---- Chevron ---- */
  .faq-chevron {
    flex-shrink: 0;
    /* Set stroke directly as a CSS property (overrides SVG presentation attribute)
       rather than relying on color → currentColor, which can be unreliable with
       Astro scoped styles on inline SVG elements */
    stroke: var(--color-primary);
    fill: none;
    opacity: 0.75;
    transition: transform 200ms ease;
  }

  .faq-item.is-open .faq-chevron {
    transform: rotate(180deg);
  }

  /* ---- Answer panel — grid-template-rows animation ---- */
  .faq-content {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 200ms ease;
  }

  .faq-item.is-open .faq-content {
    grid-template-rows: 1fr;
  }

  /* min-height: 0 is required for the 0fr grid trick to work */
  .faq-content-inner {
    min-height: 0;
    overflow: hidden;
    background-color: var(--color-tint);
    border-top: 1px solid var(--color-secondary);
  }

  .faq-content-inner p {
    padding: 16px 24px 24px 24px;
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.72;
    margin: 0;
  }

  .faq-content-inner a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--transition);
  }

  .faq-content-inner a:hover {
    color: var(--color-link-hover);
  }

  /* ---- Sign-off block ---- */
  .faq-signoff {
    margin-top: 64px;
    padding: 48px 40px;
    background-color: var(--color-tint);
    border-radius: var(--radius-card);
    text-align: center;
    border: 1px solid var(--color-secondary);
  }

  .faq-signoff__heading {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 24px;
  }

  .faq-signoff__btns {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ---- Responsive ---- */
  @media (max-width: 600px) {
    .faq-btn {
      padding: 18px 18px;
      min-height: 56px;
    }

    .faq-content-inner p {
      padding: 14px 18px 20px 18px;
    }

    .faq-signoff {
      padding: 36px 24px;
    }

    .faq-signoff__heading {
      font-size: 1.25rem;
    }
  }
</style>

<script>
  const faqItems = document.querySelectorAll<HTMLElement>('.faq-item');

  // MULTI-OPEN accordion: each button toggles ONLY its own panel.
  // Clicking question X does NOT close any other open questions.
  // This is intentional — the more common exclusive-accordion pattern (where
  // opening one item closes all others) is deliberately NOT used here.
  // Each item operates independently.

  faqItems.forEach(item => {
    const btn = item.querySelector<HTMLButtonElement>('.faq-btn');
    if (!btn) return;

    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!isOpen));
      item.classList.toggle('is-open', !isOpen);
    });
  });
</script>
