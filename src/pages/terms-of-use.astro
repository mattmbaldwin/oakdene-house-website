---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Terms of Use — Oakdene House Foundation"
  description="Terms of Use for the Oakdene House Foundation website at oakdenehouse.org.au."
>

  <!-- HERO -->
  <section class="legal-hero" aria-label="Terms of Use">
    <div class="container legal-hero__content">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span aria-current="page">Terms of Use</span>
      </nav>
      <h1>Terms of Use</h1>
    </div>
  </section>

  <!-- DOCUMENT BODY -->
  <section class="section" aria-label="Terms of Use content">
    <div class="container">
      <div class="doc-wrap">

        <!-- Dates -->
        <div class="doc-meta">
          <p><em>Effective Date: April 2026</em></p>
          <p><em>ABN: 90 151 950 926 | Registered Charity</em></p>
        </div>

        <!-- Table of contents -->
        <nav class="doc-toc" aria-label="Page contents">
          <p class="doc-toc__heading">Contents</p>
          <ol class="doc-toc__list">
            <li><a href="#section-1">1. Acceptance of Terms</a></li>
            <li><a href="#section-2">2. About Oakdene House Foundation</a></li>
            <li><a href="#section-3">3. Permitted Use of the Website</a></li>
            <li><a href="#section-4">4. Website Content — General Information Only</a></li>
            <li><a href="#section-5">5. Intellectual Property</a></li>
            <li><a href="#section-6">6. Third-Party Links and Resources</a></li>
            <li><a href="#section-7">7. Online Forms and User Submissions</a></li>
            <li><a href="#section-8">8. Privacy</a></li>
            <li><a href="#section-9">9. Limitation of Liability</a></li>
            <li><a href="#section-10">10. Privacy and Serious Invasions of Privacy</a></li>
            <li><a href="#section-11">11. Website Availability</a></li>
            <li><a href="#section-12">12. Children and Vulnerable Persons</a></li>
            <li><a href="#section-13">13. Indemnity</a></li>
            <li><a href="#section-14">14. Governing Law</a></li>
            <li><a href="#section-15">15. Changes to These Terms</a></li>
            <li><a href="#section-16">16. Contact Us</a></li>
          </ol>
        </nav>

        <!-- Section 1 -->
        <div class="doc-section" id="section-1">
          <h2>1. Acceptance of Terms</h2>
          <p>These Terms of Use (Terms) govern your access to and use of the Oakdene House Foundation website located at oakdenehouse.org.au and any associated pages or digital content (the Website).</p>
          <p>By accessing or using the Website, you acknowledge that you have read, understood, and agree to be bound by these Terms. If you do not agree to these Terms, you must not access or use the Website.</p>
          <p>These Terms apply to all visitors, users, and anyone who accesses or uses the Website.</p>
        </div>

        <!-- Section 2 -->
        <div class="doc-section" id="section-2">
          <h2>2. About Oakdene House Foundation</h2>
          <p>Oakdene House Foundation (ABN: 90 151 950 926) is a registered Australian charity based in Fairfield, Western Sydney.</p>
          <p>We support individuals and families affected by addiction, hardship, homelessness, and other life challenges through counselling, community programs, practical assistance, referral pathways, and related support services.</p>
          <p>Our Website is operated for community information and support access purposes. It is not a commercial platform and does not operate for profit.</p>
        </div>

        <!-- Section 3 -->
        <div class="doc-section" id="section-3">
          <h2>3. Permitted Use of the Website</h2>
          <p>You may access and use the Website for personal, non-commercial purposes only, including to:</p>
          <ul>
            <li>Learn about our services and programs</li>
            <li>Submit enquiries, referrals, or support requests</li>
            <li>Access publicly available resources and information</li>
            <li>Contact our organisation</li>
          </ul>
          <p>You must not use the Website to:</p>
          <ul>
            <li>Engage in any conduct that is unlawful, harmful, threatening, abusive, harassing, defamatory, or otherwise objectionable</li>
            <li>Transmit, distribute, or post any material that infringes the intellectual property rights of any person</li>
            <li>Attempt to gain unauthorised access to any part of the Website, our systems, or any related networks</li>
            <li>Introduce viruses, malware, or other harmful code</li>
            <li>Use automated tools (such as bots or scrapers) to access, collect, or monitor Website content without our prior written consent</li>
            <li>Impersonate any person or entity, or misrepresent your affiliation with any person or entity</li>
            <li>Collect, record, or use personal information about other users of the Website in a manner inconsistent with applicable privacy laws</li>
            <li>Use the Website in a manner that could damage, disable, overburden, or impair its functionality</li>
          </ul>
        </div>

        <!-- Section 4 -->
        <div class="doc-section" id="section-4">
          <h2>4. Website Content — General Information Only</h2>
          <p>The content on our Website is provided for general information and community access purposes only. It is not intended to constitute, and does not constitute:</p>
          <ul>
            <li>Professional medical, health, mental health, or clinical advice</li>
            <li>Legal or financial advice</li>
            <li>A substitute for professional counselling or therapeutic services</li>
          </ul>
          <p>Whilst we endeavour to keep the information on our Website accurate and current, Oakdene House Foundation makes no representations or warranties of any kind, express or implied, regarding the completeness, accuracy, reliability, suitability, or availability of the information, products, services, or related graphics on the Website.</p>
          <p>If you are in crisis or require immediate support, please contact emergency services on 000 or a crisis helpline such as Lifeline on 13 11 14.</p>
        </div>

        <!-- Section 5 -->
        <div class="doc-section" id="section-5">
          <h2>5. Intellectual Property</h2>
          <p>All content on this Website, including but not limited to text, graphics, logos, images, icons, and software, is the property of Oakdene House Foundation or its content suppliers and is protected by Australian copyright law.</p>
          <p>You may:</p>
          <ul>
            <li>View, download, and print Website content for your personal, non-commercial use</li>
            <li>Share links to our Website content on social media or other platforms</li>
          </ul>
          <p>You must not, without our prior written consent:</p>
          <ul>
            <li>Reproduce, republish, distribute, sell, or commercially exploit any content from our Website</li>
            <li>Use our name, logo, or branding in any way that suggests affiliation, endorsement, or sponsorship</li>
            <li>Remove or alter any copyright, trademark, or other proprietary notices</li>
          </ul>
        </div>

        <!-- Section 6 -->
        <div class="doc-section" id="section-6">
          <h2>6. Third-Party Links and Resources</h2>
          <p>Our Website may contain links to external websites and resources operated by third parties, including government agencies, community service providers, and referral partners. These links are provided for your convenience and information only.</p>
          <p>Oakdene House Foundation does not control, endorse, or accept responsibility for the content, privacy practices, or availability of any third-party websites. We encourage you to review the terms of use and privacy policies of any external sites you visit.</p>
        </div>

        <!-- Section 7 -->
        <div class="doc-section" id="section-7">
          <h2>7. Online Forms and User Submissions</h2>
          <p>Our Website includes online forms for enquiries, referrals, volunteer applications, and program interest. By submitting a form, you confirm that:</p>
          <ul>
            <li>The information you provide is accurate and complete to the best of your knowledge</li>
            <li>You are authorised to provide the information submitted</li>
            <li>You consent to us using that information in accordance with our Privacy Policy</li>
          </ul>
          <p>We reserve the right to decline, disregard, or not respond to any submission that is abusive, inappropriate, or otherwise contrary to these Terms.</p>
          <p>Submission of an online form does not guarantee the provision of any particular service. Our team will be in contact to discuss your needs and available options.</p>
        </div>

        <!-- Section 8 -->
        <div class="doc-section" id="section-8">
          <h2>8. Privacy</h2>
          <p>Your use of the Website and any personal information you provide to us is governed by our Privacy Policy, which is incorporated into and forms part of these Terms. Our Privacy Policy explains how we collect, use, and protect your personal information in accordance with the Privacy Act 1988 (Cth), the Australian Privacy Principles (APPs), and the Health Records and Information Privacy Act 2002 (NSW) (HRIP Act).</p>
          <p>We treat personal information about our clients, donors, and community members with the highest degree of respect and confidentiality. We do not use personal information for direct marketing without consent, and we do not sell or trade personal information to third parties.</p>
          <p>Please review our <a href="/privacy-policy/">Privacy Policy</a>, which is available on our Website.</p>
        </div>

        <!-- Section 9 -->
        <div class="doc-section" id="section-9">
          <h2>9. Limitation of Liability</h2>
          <p>To the maximum extent permitted by law, Oakdene House Foundation, its officers, employees, volunteers, and agents exclude all liability for any loss or damage (including consequential loss) arising from:</p>
          <ul>
            <li>Your use of, or reliance on, the content or services available through the Website</li>
            <li>Any interruption, suspension, or unavailability of the Website</li>
            <li>Any errors, omissions, or inaccuracies in Website content</li>
            <li>Unauthorised access to, or alteration of, your data or transmissions</li>
            <li>Any content or conduct of third parties accessible through the Website</li>
          </ul>
          <p>Nothing in these Terms limits or excludes any rights or guarantees that cannot be excluded under the Australian Consumer Law or any other applicable law.</p>
        </div>

        <!-- Section 10 -->
        <div class="doc-section" id="section-10">
          <h2>10. Privacy and Serious Invasions of Privacy</h2>
          <p>In addition to our obligations under the Privacy Act and these Terms, please note that from 10 June 2025, Australian law recognises a tort of serious invasion of privacy. This means individuals may have a cause of action where personal information about them has been collected, used, or disclosed in a way that seriously and intentionally or recklessly invades their privacy, and where their reasonable expectation of privacy was not respected.</p>
          <p>Oakdene House Foundation is committed to handling all personal information, including information submitted through this Website, in a manner that respects privacy and complies with all applicable laws. If you have concerns about how your personal information has been handled, please contact our Privacy Officer in the first instance.</p>
        </div>

        <!-- Section 11 -->
        <div class="doc-section" id="section-11">
          <h2>11. Website Availability</h2>
          <p>We aim to make our Website available at all times, but we do not guarantee that the Website will be continuously available or free from errors. We may suspend, withdraw, or restrict access to some or all of the Website at any time without notice for operational, maintenance, or security reasons.</p>
        </div>

        <!-- Section 12 -->
        <div class="doc-section" id="section-12">
          <h2>12. Children and Vulnerable Persons</h2>
          <p>Our Website is intended for use by adults and by service providers, carers, or family members seeking information on behalf of others. Our Website is not directed at children under the age of 18.</p>
          <p>If you are accessing our services on behalf of a child or a person who may be vulnerable, please contact us directly so that we can ensure that appropriate safeguards and support processes are in place. We apply additional care when collecting information about or on behalf of children, young people, or persons with compromised capacity to consent, and we may require involvement of a parent, guardian, or responsible person.</p>
        </div>

        <!-- Section 13 -->
        <div class="doc-section" id="section-13">
          <h2>13. Indemnity</h2>
          <p>By using our Website, you agree to indemnify and hold harmless Oakdene House Foundation, its officers, employees, volunteers, and agents from and against any claims, liabilities, damages, losses, and expenses (including reasonable legal fees) arising out of or in any way connected with:</p>
          <ul>
            <li>Your access to or use of the Website</li>
            <li>Your breach of these Terms</li>
            <li>Any content you submit through the Website</li>
            <li>Your violation of any applicable law or the rights of any third party</li>
          </ul>
        </div>

        <!-- Section 14 -->
        <div class="doc-section" id="section-14">
          <h2>14. Governing Law</h2>
          <p>These Terms are governed by the laws of New South Wales, Australia. Any disputes arising under or in connection with these Terms shall be subject to the exclusive jurisdiction of the courts of New South Wales.</p>
        </div>

        <!-- Section 15 -->
        <div class="doc-section" id="section-15">
          <h2>15. Changes to These Terms</h2>
          <p>These Terms of Use were last updated in April 2026. We may update these Terms from time to time to reflect changes in our Website, services, or applicable law. Changes will take effect from the date they are published on the Website. Your continued use of the Website after any changes constitutes your acceptance of the updated Terms.</p>
          <p>We encourage you to review these Terms periodically.</p>
        </div>

        <!-- Section 16 -->
        <div class="doc-section" id="section-16">
          <h2>16. Contact Us</h2>
          <p>If you have any questions or concerns about these Terms, please contact us:</p>
          <div class="doc-address doc-contact-card">
            <p><strong>Oakdene House Foundation</strong></p>
            <p>Address: 29 Vine St, Fairfield NSW 2165</p>
            <p>Email: <a href="mailto:admin@oakdenehouse.org.au">admin@oakdenehouse.org.au</a></p>
            <p>Phone: <a href="tel:0287170999">02 8717 0999</a></p>
            <p>Website: <a href="https://www.oakdenehouse.org.au" target="_blank" rel="noopener noreferrer">www.oakdenehouse.org.au</a></p>
          </div>
          <p>These Terms of Use should be read together with our Privacy Policy. Both documents are available on our Website.</p>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ---- Hero ---- */
  .legal-hero {
    background-color: var(--color-primary);
    padding-block: 52px 44px;
  }

  .legal-hero h1 {
    color: var(--color-white);
    margin-bottom: 0;
  }

  /* ---- Document wrapper ---- */
  .doc-wrap {
    max-width: 760px;
    margin-inline: auto;
  }

  /* ---- Dates metadata ---- */
  .doc-meta {
    padding: 18px 22px;
    background-color: var(--color-tint);
    border-left: 3px solid var(--color-secondary);
    border-radius: 0 var(--radius-card) var(--radius-card) 0;
    margin-bottom: 36px;
  }

  .doc-meta p {
    margin-bottom: 4px;
    font-size: 0.9375rem;
    color: var(--color-muted);
  }

  .doc-meta p:last-child {
    margin-bottom: 0;
  }

  /* ---- Table of contents ---- */
  .doc-toc {
    background-color: var(--color-tint);
    border: 1px solid var(--color-secondary);
    border-radius: var(--radius-card);
    padding: 22px 28px;
    margin-bottom: 52px;
  }

  .doc-toc__heading {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 14px;
  }

  .doc-toc__list {
    display: flex;
    flex-direction: column;
    gap: 7px;
    padding-left: 18px;
    margin-bottom: 0;
  }

  .doc-toc__list a {
    font-size: 0.9rem;
    color: var(--color-primary);
    text-decoration: none;
    transition: color var(--transition);
  }

  .doc-toc__list a:hover {
    color: var(--color-link-hover);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ---- Document sections ---- */
  .doc-section {
    margin-bottom: 48px;
  }

  .doc-section:last-child {
    margin-bottom: 0;
  }

  .doc-section h2 {
    margin-bottom: 18px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-secondary);
    scroll-margin-top: 88px;
  }

  .doc-section p {
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.72;
    margin-bottom: 16px;
  }

  .doc-section p:last-child {
    margin-bottom: 0;
  }

  .doc-section ul {
    padding-left: 22px;
    margin-bottom: 16px;
  }

  .doc-section li {
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.65;
    margin-bottom: 7px;
  }

  .doc-section a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--transition);
  }

  .doc-section a:hover {
    color: var(--color-link-hover);
  }

  /* ---- Address / contact card ---- */
  .doc-address {
    background-color: var(--color-tint);
    border: 1px solid var(--color-secondary);
    border-radius: var(--radius-card);
    padding: 20px 24px;
    margin-bottom: 16px;
  }

  .doc-address p {
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.6;
    margin-bottom: 6px;
  }

  .doc-address p:last-child {
    margin-bottom: 0;
  }

  .doc-address a {
    color: var(--color-primary);
    text-decoration: none;
    transition: color var(--transition);
  }

  .doc-address a:hover {
    text-decoration: underline;
  }

  .doc-contact-card {
    border-left: 3px solid var(--color-primary);
    border-radius: 0 var(--radius-card) var(--radius-card) 0;
    margin-top: 20px;
    margin-bottom: 20px;
  }
</style>
