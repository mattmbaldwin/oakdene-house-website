---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Our Board — Oakdene House Foundation"
  description="Oakdene House Foundation is guided by a committed Board providing governance, oversight and strategic direction for our community charity in Fairfield, Western Sydney."
  ogImage="/images/centre/exterior-exterior-1-img_2651.jpg"
  noindex={true}
>

  <!-- HERO -->
  <section class="board-hero" aria-label="Our Board">
    <div class="container board-hero__content">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <a href="/about/">About</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span aria-current="page">Our Board</span>
      </nav>
      <h1>Our Board</h1>
    </div>
  </section>

  <!-- HOLDING MESSAGE -->
  <section class="section" aria-label="Board profiles">
    <div class="container holding-container">
      <h2>Board profiles</h2>
      <p>Our Board profiles are currently being updated. For Board enquiries, please contact us at <a href="mailto:admin@oakdenehouse.org.au">admin@oakdenehouse.org.au</a> or call <a href="tel:+61287170999">(02) 8717 0999</a>.</p>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .board-hero {
    background-color: var(--color-primary);
    padding-block: 72px 64px;
  }

  .board-hero__content h1 {
    color: var(--color-white);
    margin-bottom: 0;
  }

  /* Holding message */
  .holding-container {
    max-width: 680px;
  }

  .holding-container h2 {
    margin-bottom: 16px;
  }

  .holding-container p {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-text);
  }

  .holding-container a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--transition);
  }

  .holding-container a:hover {
    color: var(--color-link-hover);
  }
</style>
