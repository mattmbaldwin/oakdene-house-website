---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/CTABand.astro';
import directory from '../content/directory.json';

const categories = [
  { name: 'Counselling', description: 'Mental health and wellbeing support from qualified counsellors.', icon: 'heart' },
  { name: 'Housing Support', description: 'Services to help with housing, homelessness, and housing assistance.', icon: 'home' },
  { name: 'Legal Support', description: 'Free and low-cost legal advice and representation.', icon: 'scale' },
  { name: 'Family Support', description: 'Services for families, parenting, and relationships.', icon: 'people' },
  { name: 'Crisis Support', description: '24-hour support for people in crisis or emergency situations.', icon: 'alert' },
  { name: 'Alcohol and Other Drug Services', description: 'Support for substance use, addiction, and recovery.', icon: 'shield' },
  { name: 'Community Support', description: 'Community programs, practical help, and local services.', icon: 'star' },
];
---

<BaseLayout
  title="Service Directory — Oakdene House Foundation"
  description="Community service directory from Oakdene House Foundation — counselling, housing, legal support, family services, crisis lines, AOD support and community programs in Western Sydney."
>

  <!-- HERO — dark teal, no image -->
  <section class="dir-hero" aria-label="Service Directory">
    <div class="container dir-hero__content">
      <h1>Community service directory</h1>
      <p class="dir-hero__lead">Browse support options and local services, or contact Oakdene if you would like help working out the best fit.</p>
    </div>
  </section>

  <!-- CATEGORIES -->
  <section class="section" aria-labelledby="categories-heading">
    <div class="container">
      <div class="section-heading section-heading--center">
        <p class="section-heading__eyebrow">Browse by Category</p>
        <h2 id="categories-heading">Types of support available</h2>
      </div>
      <div class="cat-grid">
        {categories.map(cat => (
          <div class="cat-card">
            <div class="cat-card__icon" aria-hidden="true">
              {cat.icon === 'heart' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              )}
              {cat.icon === 'home' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              )}
              {cat.icon === 'scale' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="3" x2="12" y2="21"/><path d="M3 9l4-4 4 4M17 5l4 4-4 4"/><line x1="3" y1="21" x2="21" y2="21"/></svg>
              )}
              {cat.icon === 'people' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              )}
              {cat.icon === 'alert' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.09 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 5.98 5.98l1.28-1.28a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.02z"/></svg>
              )}
              {cat.icon === 'shield' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              )}
              {cat.icon === 'star' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              )}
            </div>
            <h3 class="cat-card__name">{cat.name}</h3>
            <p class="cat-card__desc">{cat.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DIRECTORY LISTINGS -->
  <section class="section section--tint" aria-labelledby="listings-heading">
    <div class="container">
      <div class="section-heading section-heading--center">
        <p class="section-heading__eyebrow">Service Listings</p>
        <h2 id="listings-heading">Community services and support</h2>
      </div>
      <div class="listings-grid">
        {directory.map(entry => (
          <article class="listing-card">
            <div class="listing-card__header">
              <h3 class="listing-card__name">{entry.name}</h3>
              <span class="listing-card__category">{entry.category}</span>
            </div>
            <p class="listing-card__summary">{entry.summary}</p>
            <div class="listing-card__footer">
              {entry.phone && (
                <a href={`tel:${entry.phone.replace(/\s/g, '')}`} class="listing-card__phone">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.09 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 5.98 5.98l1.28-1.28a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.02z"/></svg>
                  {entry.phone}
                </a>
              )}
              {entry.website && (
                <a href={entry.website} class="listing-card__website" target="_blank" rel="noopener noreferrer">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                  Visit website
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- DISCLAIMER -->
  <section class="section" aria-label="Directory disclaimer">
    <div class="container">
      <div class="disclaimer">
        <div class="disclaimer__icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <p>Service details can change over time. Please contact the listed service directly to confirm current eligibility, opening hours, and referral requirements. Oakdene does not endorse any specific service.</p>
      </div>
    </div>
  </section>

  <!-- NOT SURE WHERE TO START -->
  <section class="section section--tint" aria-labelledby="help-heading">
    <div class="container">
      <div class="help-inner">
        <div class="section-heading section-heading--center">
          <p class="section-heading__eyebrow">Need Help Navigating?</p>
          <h2 id="help-heading">Not sure where to start?</h2>
        </div>
        <p class="help-text">Navigating the service system can be overwhelming. If you would like help finding the right support, our team can talk you through your options.</p>
        <div class="btn-group help-btns">
          <a href="/contact/" class="btn btn--primary">Contact Us for Guidance</a>
          <a href="/need-help-now/" class="btn btn--secondary">Need Help Now</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABand
    heading="We can help you find the right service"
    primaryBtn={{ text: 'Contact Us for Guidance', href: '/contact/' }}
    secondaryBtn={{ text: 'Browse Resources', href: '/resources/' }}
    dark={true}
  />

</BaseLayout>

<style>
  /* Hero */
  .dir-hero {
    background-color: var(--color-primary);
    padding-block: 72px 64px;
  }

  .dir-hero__content {
    max-width: 680px;
  }

  .dir-hero__content h1 {
    color: var(--color-white);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 16px;
  }

  .dir-hero__lead {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.88);
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* Category grid */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .cat-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-secondary);
    border-radius: var(--radius-card);
    padding: 24px 20px;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .cat-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card);
  }

  .cat-card__icon {
    color: var(--color-primary);
    margin-bottom: 12px;
  }

  .cat-card__name {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .cat-card__desc {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.55;
    margin-bottom: 0;
  }

  /* Directory listings */
  .listings-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .listing-card {
    background-color: var(--color-white);
    border-radius: var(--radius-card);
    border: 1px solid var(--color-secondary);
    padding: 24px;
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
  }

  .listing-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }

  .listing-card__name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0;
    line-height: 1.3;
  }

  .listing-card__category {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary-hover);
    background-color: var(--color-tint);
    border-radius: 12px;
    padding: 3px 10px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .listing-card__summary {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: 16px;
    flex: 1;
  }

  .listing-card__footer {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    align-items: center;
    border-top: 1px solid var(--color-secondary);
    padding-top: 14px;
  }

  .listing-card__phone,
  .listing-card__website {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }

  .listing-card__phone:hover,
  .listing-card__website:hover {
    text-decoration: underline;
  }

  /* Disclaimer */
  .disclaimer {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    max-width: 720px;
    background-color: var(--color-tint);
    border-radius: var(--radius-card);
    border: 1px solid var(--color-secondary);
    padding: 20px 24px;
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .disclaimer__icon {
    color: var(--color-primary);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .disclaimer p {
    margin-bottom: 0;
  }

  /* Not sure */
  .help-inner {
    max-width: 560px;
    margin-inline: auto;
    text-align: center;
  }

  .help-text {
    font-size: 1.0625rem;
    color: var(--color-text);
    line-height: 1.7;
    margin-bottom: 28px;
  }

  .help-btns {
    justify-content: center;
  }

  @media (max-width: 1024px) {
    .cat-grid { grid-template-columns: repeat(3, 1fr); }
    .listings-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .cat-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .cat-grid { grid-template-columns: 1fr; }
    .listings-grid { grid-template-columns: 1fr; }
  }
</style>
