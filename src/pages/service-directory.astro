---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/CTABand.astro';
import directoryData from '../content/oakdene-service-directory.json';

const { services, meta } = directoryData;
const total = meta.totalServices; // 318

// Suppress "by [organisation]" subtitle when one string contains the other
function showOrg(serviceName: string, organisation: string): boolean {
  if (!organisation) return false;
  const a = serviceName.trim().toLowerCase();
  const b = organisation.trim().toLowerCase();
  return a !== b && !a.includes(b) && !b.includes(a);
}

// Coverage badge — only these 5 tiers get a badge
const BADGE_TIERS = new Set(['Local', 'Regional', 'Statewide', 'National', 'Telehealth']);

function badgeVariant(coverage: string | null | undefined): string | null {
  if (!coverage || !BADGE_TIERS.has(coverage)) return null;
  return coverage.toLowerCase();
}

// Location display — prefer suburb, fall back to coverage label
function locationText(
  suburb: string | null | undefined,
  lga: string | null | undefined,
  coverage: string | null | undefined
): string | null {
  const usableSuburb = suburb && !suburb.includes('N/A') ? suburb.trim() : null;
  if (usableSuburb) {
    return lga ? `${usableSuburb}, ${lga}` : usableSuburb;
  }
  if (!coverage || !BADGE_TIERS.has(coverage)) return null;
  if (coverage === 'National') return 'National service';
  if (coverage === 'Telehealth') return 'Telehealth (online)';
  return coverage; // Local, Regional, Statewide
}

// Category secondary label — show if it adds info beyond the group name
function showCategory(category: string | null | undefined, group: string | null | undefined): boolean {
  if (!category || !group) return false;
  return category !== group && !group.toLowerCase().includes(category.toLowerCase());
}

// Format meta.lastVerified ("2026-04-29") → "29 April 2026"
const verifiedDate = new Date(meta.lastVerified + 'T00:00:00');
const verifiedFormatted = verifiedDate.toLocaleDateString('en-AU', {
  day: 'numeric', month: 'long', year: 'numeric'
});

// otherDirectories — skip the header row if the source data fix hasn't landed
const otherDirs = directoryData.otherDirectories.filter((d: any) => d.name !== 'Name');
---

<BaseLayout
  title="Community Service Directory — Oakdene House Foundation"
  description="Browse 318 support services across Western Sydney and beyond — counselling, housing, legal, family, AOD, mental health and more. Curated by Oakdene House Foundation."
>

  <!-- HERO -->
  <section class="dir-hero" aria-label="Service directory">
    <div class="container dir-hero__inner">
      <h1>Community service directory</h1>
      <p class="dir-hero__lead">Browse {total} support services across Western Sydney and beyond, or contact Oakdene if you'd like help working out the best fit.</p>
    </div>
  </section>

  <!-- FILTER BAR -->
  <div class="filter-bar" id="filter-bar" role="search" aria-label="Filter services">
    <div class="container filter-bar__inner">
      <div class="filter-bar__field">
        <label for="search-input" class="filter-bar__label">Search</label>
        <div class="filter-bar__input-wrap">
          <svg class="filter-bar__search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input
            type="search"
            id="search-input"
            class="filter-bar__search"
            placeholder="Search by name, organisation or service type…"
            autocomplete="off"
          />
        </div>
      </div>
      <div class="filter-bar__field filter-bar__field--select">
        <label for="group-select" class="filter-bar__label">Category</label>
        <select id="group-select" class="filter-bar__select">
          <option value="">All categories ({total})</option>
          {directoryData.categoryGroups.map(g => (
            <option value={g.name}>{g.name} ({g.count})</option>
          ))}
        </select>
      </div>
      <div class="filter-bar__field filter-bar__field--select">
        <label for="coverage-select" class="filter-bar__label">Location</label>
        <select id="coverage-select" class="filter-bar__select">
          <option value="">All locations</option>
          <option value="Local">Local</option>
          <option value="Regional">Regional</option>
          <option value="Statewide">Statewide</option>
          <option value="National">National</option>
          <option value="Telehealth">Telehealth</option>
        </select>
      </div>
    </div>
  </div>

  <!-- RESULT COUNT -->
  <div class="result-bar" aria-live="polite" aria-atomic="true">
    <div class="container">
      <p class="result-count" id="result-count">Showing {total} of {total} services</p>
    </div>
  </div>

  <!-- SERVICE CARDS -->
  <section class="section section--tint section--cards" aria-labelledby="listings-heading">
    <div class="container">
      <h2 id="listings-heading" class="sr-only">Service listings</h2>
      <div class="cards-grid" id="cards-grid">
        {services.map((s) => {
          const phone    = s.contact?.phone   ?? null;
          const email    = s.contact?.email   ?? null;
          const website  = s.contact?.website ?? null;
          const hasContact = !!(phone || email || website);

          const orgVisible = showOrg(s.serviceName, s.organisation);
          const coverage   = s.location?.coverage ?? null;
          const badge      = badgeVariant(coverage);
          const locText    = locationText(s.location?.suburb, s.location?.lga, coverage);
          const catVisible = showCategory(s.category, s.categoryGroup);

          const social     = s.social ?? {};
          const socialEntries = Object.entries(social).filter(([, url]) => !!url) as [string, string][];
          const hasSocial  = socialEntries.length > 0;
          const acncLink   = s.identifiers?.acncLink ?? null;
          const hasFooter  = hasSocial || !!acncLink;

          return (
            <article
              class="svc-card"
              data-name={s.serviceName.toLowerCase()}
              data-org={(s.organisation ?? '').toLowerCase()}
              data-type={(s.serviceType ?? '').toLowerCase()}
              data-group={s.categoryGroup ?? ''}
              data-coverage={coverage ?? ''}
            >
              {/* ── Header: name + badge ── */}
              <div class="svc-card__header">
                <div class="svc-card__title-group">
                  <h3 class="svc-card__name">{s.serviceName}</h3>
                  {orgVisible && <p class="svc-card__org">by {s.organisation}</p>}
                </div>
                {badge && (
                  <span class={`svc-card__badge svc-card__badge--${badge}`}>{coverage}</span>
                )}
              </div>

              {/* ── Meta: category group + optional fine category + type ── */}
              <div class="svc-card__meta">
                <span class="svc-card__group">{s.categoryGroup}</span>
                {catVisible && (
                  <p class="svc-card__category">{s.category}</p>
                )}
                {s.serviceType && (
                  <p class="svc-card__type">{s.serviceType}</p>
                )}
              </div>

              {/* ── Contact ── */}
              <div class="svc-card__contact">
                {hasContact ? (
                  <>
                    {phone && (
                      <a href={`tel:${phone.replace(/\s/g, '')}`} class="svc-card__contact-link">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.09 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 5.98 5.98l1.28-1.28a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.02z"/></svg>
                        {phone}
                      </a>
                    )}
                    {email && (
                      <a href={`mailto:${email}`} class="svc-card__contact-link">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,12 2,6"/></svg>
                        {email}
                      </a>
                    )}
                    {website && (
                      <a href={website} class="svc-card__contact-link" target="_blank" rel="noopener noreferrer">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                        Visit website
                      </a>
                    )}
                  </>
                ) : (
                  <p class="svc-card__no-contact">Contact details unavailable</p>
                )}
              </div>

              {/* ── Location ── */}
              {locText && (
                <p class="svc-card__location" aria-label={`Location: ${locText}`}>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  {locText}
                </p>
              )}

              {/* ── Footer: social + ACNC ── */}
              {hasFooter && (
                <div class="svc-card__footer">
                  {hasSocial && (
                    <div class="svc-card__socials">
                      {socialEntries.map(([platform, url]) => (
                        <a
                          href={url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="svc-card__social-link"
                          aria-label={`${s.serviceName} on ${platform.charAt(0).toUpperCase() + platform.slice(1)}`}
                        >
                          {platform === 'facebook' && (
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                          )}
                          {platform === 'instagram' && (
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                          )}
                          {platform === 'linkedin' && (
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                          )}
                          {platform === 'twitter' && (
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4l16 16M20 4L4 20"/></svg>
                          )}
                          {platform === 'youtube' && (
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
                          )}
                          {platform === 'tiktok' && (
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
                          )}
                        </a>
                      ))}
                    </div>
                  )}
                  {acncLink && (
                    <a href={acncLink} target="_blank" rel="noopener noreferrer" class="svc-card__acnc">
                      Verify on ACNC →
                    </a>
                  )}
                </div>
              )}
            </article>
          );
        })}
      </div>

      <!-- Empty state — shown by filter JS -->
      <div class="empty-state" id="empty-state" style="display:none">
        <p>No services match those filters. Try widening your search, or browse the <a href="#other-directories">wider directories below</a>.</p>
      </div>
    </div>
  </section>

  <!-- DISCLAIMER -->
  <section class="section" aria-label="Directory disclaimer">
    <div class="container">
      <div class="disclaimer">
        <svg class="disclaimer__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p>Service details can change over time. Please contact the listed service directly to confirm current eligibility, opening hours, and referral requirements. Oakdene does not endorse any specific service. Directory last verified {verifiedFormatted}.</p>
      </div>
    </div>
  </section>

  <!-- OTHER DIRECTORIES -->
  <section class="section section--tint" id="other-directories" aria-labelledby="other-dir-heading">
    <div class="container">
      <div class="section-heading">
        <p class="section-heading__eyebrow">Going Further</p>
        <h2 id="other-dir-heading">Can't find what you need? Try these wider directories.</h2>
        <p class="other-dir__intro">When a service isn't in our directory, these registers and finders can help. Many of our listed services cross-reference these.</p>
      </div>
      <div class="other-dir-grid">
        {otherDirs.map((d: any) => (
          <article class="other-dir-card">
            <div class="other-dir-card__header">
              <a
                href={d.url}
                target="_blank"
                rel="noopener noreferrer"
                class="other-dir-card__name"
              >
                {d.name}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </a>
            </div>
            {d.operator && (
              <p class="other-dir-card__operator">{d.operator}</p>
            )}
            {d.coverage && (
              <p class="other-dir-card__coverage-text">{d.coverage}</p>
            )}
            {d.bestFor && (
              <p class="other-dir-card__best-for">{d.bestFor}</p>
            )}
            {d.notes && (
              <p class="other-dir-card__notes">{d.notes}</p>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABand
    heading="Need help working out where to start?"
    primaryBtn={{ text: 'Contact Us', href: '/contact/' }}
    secondaryBtn={{ text: 'Get Support', href: '/forms/' }}
    dark={true}
  />

<script>
  (function () {
    const TOTAL = 318;
    const searchInput    = document.getElementById('search-input')    as HTMLInputElement;
    const groupSelect    = document.getElementById('group-select')    as HTMLSelectElement;
    const coverageSelect = document.getElementById('coverage-select') as HTMLSelectElement;
    const resultCount    = document.getElementById('result-count')    as HTMLElement;
    const cardsGrid      = document.getElementById('cards-grid')      as HTMLElement;
    const emptyState     = document.getElementById('empty-state')     as HTMLElement;

    if (!searchInput || !groupSelect || !coverageSelect) return;

    const cards = Array.from(cardsGrid.querySelectorAll<HTMLElement>('article.svc-card'));

    function applyFilters() {
      const query    = searchInput.value.toLowerCase().trim();
      const group    = groupSelect.value;
      const coverage = coverageSelect.value;

      let visible = 0;

      cards.forEach(card => {
        const matchSearch =
          !query ||
          (card.dataset.name  ?? '').includes(query) ||
          (card.dataset.org   ?? '').includes(query) ||
          (card.dataset.type  ?? '').includes(query);

        const matchGroup    = !group    || card.dataset.group    === group;
        const matchCoverage = !coverage || card.dataset.coverage === coverage;

        const show = matchSearch && matchGroup && matchCoverage;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      resultCount.textContent = `Showing ${visible} of ${TOTAL} services`;
      emptyState.style.display = visible === 0 ? '' : 'none';
    }

    searchInput.addEventListener('input', applyFilters);
    groupSelect.addEventListener('change', applyFilters);
    coverageSelect.addEventListener('change', applyFilters);
  })();
</script>

</BaseLayout>

<style>
  /* ── Utilities ───────────────────────────────────────────── */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Hero ────────────────────────────────────────────────── */
  .dir-hero {
    background-color: var(--color-primary);
    padding-block: 72px 64px;
  }

  .dir-hero__inner {
    max-width: 680px;
  }

  .dir-hero h1 {
    color: var(--color-white);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    margin-bottom: 16px;
    line-height: 1.2;
  }

  .dir-hero__lead {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.88);
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* ── Result bar ──────────────────────────────────────────── */
  .result-bar {
    padding-block: 14px;
    background-color: var(--color-white);
    border-bottom: 1px solid var(--color-secondary);
  }

  .result-count {
    font-size: 0.9375rem;
    color: var(--color-muted);
    font-weight: 500;
  }

  /* ── Cards grid ──────────────────────────────────────────── */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* ── Service card ────────────────────────────────────────── */
  .svc-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-secondary);
    border-radius: var(--radius-card);
    padding: 20px 22px;
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: box-shadow var(--transition);
  }

  .svc-card:hover {
    box-shadow: var(--shadow-card-hover);
  }

  /* Header */
  .svc-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
  }

  .svc-card__title-group {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .svc-card__name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    line-height: 1.3;
    margin-bottom: 0;
  }

  .svc-card__org {
    font-size: 0.8125rem;
    color: var(--color-muted);
    margin-bottom: 0;
  }

  /* Coverage badge */
  .svc-card__badge {
    flex-shrink: 0;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: 10px;
    padding: 3px 9px;
    white-space: nowrap;
    margin-top: 2px;
  }

  .svc-card__badge--local,
  .svc-card__badge--regional {
    background-color: var(--color-tint);
    border: 1px solid var(--color-secondary);
    color: var(--color-primary);
  }

  .svc-card__badge--statewide {
    background-color: var(--color-secondary);
    color: var(--color-primary);
  }

  .svc-card__badge--national {
    background-color: var(--color-primary);
    color: var(--color-white);
  }

  .svc-card__badge--telehealth {
    background-color: #e8e8e8;
    color: var(--color-muted);
  }

  /* Meta */
  .svc-card__meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .svc-card__group {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--color-primary);
    background-color: var(--color-tint);
    border: 1px solid var(--color-secondary);
    border-radius: 12px;
    padding: 2px 10px;
    align-self: flex-start;
  }

  .svc-card__category {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin-bottom: 0;
    line-height: 1.4;
  }

  .svc-card__type {
    font-size: 0.8125rem;
    font-style: italic;
    color: var(--color-muted);
    margin-bottom: 0;
    line-height: 1.4;
  }

  /* Contact */
  .svc-card__contact {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .svc-card__contact-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
    transition: color var(--transition);
    overflow-wrap: anywhere;
    min-width: 0;
  }

  .svc-card__contact-link:hover {
    color: var(--color-primary-hover);
    text-decoration: underline;
  }

  .svc-card__no-contact {
    font-size: 0.8125rem;
    color: var(--color-muted);
    font-style: italic;
    margin-bottom: 0;
  }

  /* Location */
  .svc-card__location {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.8125rem;
    color: var(--color-muted);
    margin-bottom: 0;
    margin-top: auto;
  }

  /* Footer: socials + ACNC */
  .svc-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding-top: 10px;
    border-top: 1px solid var(--color-secondary);
    flex-wrap: wrap;
  }

  .svc-card__socials {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .svc-card__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--transition);
  }

  .svc-card__social-link:hover {
    color: var(--color-primary);
  }

  .svc-card__acnc {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
