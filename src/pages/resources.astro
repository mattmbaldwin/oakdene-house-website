---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/CTABand.astro';

const featured = [
  {
    title: 'Getting Support Guide',
    description: 'A clear guide to understanding what support is available and how to access it.',
    icon: 'book',
  },
  {
    title: 'Referral Information Pack',
    description: 'Information for workers, health professionals, and community partners about referring to Oakdene.',
    icon: 'share',
  },
  {
    title: 'Community Support Guide',
    description: 'A directory of community services, supports, and resources in Western Sydney.',
    icon: 'map',
  },
  {
    title: 'Wellbeing and Recovery Tools',
    description: 'Practical tools, worksheets, and exercises to support your wellbeing and recovery journey.',
    icon: 'heart',
  },
];

const availableResources = [
  { label: 'Flyers and brochures', href: '/resources/flyers-and-brochures/' },
  { label: 'Information sheets', href: '/resources/information-sheets/' },
  { label: 'Referral form', href: '/forms/' },
  { label: 'Volunteer application', href: '/forms/' },
];
---

<BaseLayout
  title="Resources — Oakdene House Foundation"
  description="Browse practical guides, support information, and downloadable resources from Oakdene House Foundation, Fairfield, Western Sydney."
>

  <!-- HERO — dark teal, no image -->
  <section class="res-hero" aria-label="Resources">
    <div class="container res-hero__content">
      <h1>Resources that are practical, clear, and easy to use</h1>
      <p class="res-hero__lead">Browse guides, support information, and helpful materials you can access straight away.</p>
    </div>
  </section>

  <!-- FEATURED RESOURCES -->
  <section class="section" aria-labelledby="featured-heading">
    <div class="container">
      <div class="section-heading section-heading--center">
        <p class="section-heading__eyebrow">Featured Resources</p>
        <h2 id="featured-heading">Guides and information packs</h2>
        <p class="section-heading__lead">All resources are free to access and download.</p>
      </div>
      <div class="resources-grid">
        {featured.map(r => (
          <div class="resource-card">
            <div class="resource-card__icon" aria-hidden="true">
              {r.icon === 'book' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
              )}
              {r.icon === 'share' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
              )}
              {r.icon === 'map' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>
              )}
              {r.icon === 'heart' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              )}
            </div>
            <h3 class="resource-card__title">{r.title}</h3>
            <p class="resource-card__desc">{r.description}</p>
            <span class="resource-card__link resource-card__link--disabled" aria-disabled="true">Coming soon</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AVAILABLE RESOURCES -->
  <section class="section section--tint" aria-labelledby="available-heading">
    <div class="container">
      <div class="available-inner">
        <div class="section-heading">
          <p class="section-heading__eyebrow">Browse</p>
          <h2 id="available-heading">Available resources</h2>
        </div>
        <ul class="resource-links" role="list">
          {availableResources.map(r => (
            <li>
              <a href={r.href} class="resource-link">
                <span class="resource-link__icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </span>
                {r.label}
              </a>
            </li>
          ))}
        </ul>

        <div class="resource-note">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <p>All resources are free. If you cannot find what you are looking for, <a href="/contact/">contact our team</a> and we will help.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABand
    heading="Need more support?"
    primaryBtn={{ text: 'Get Support', href: '/forms/' }}
    secondaryBtn={{ text: 'Contact Us', href: '/contact/' }}
    dark={true}
  />

</BaseLayout>

<style>
  /* Hero — dark teal background */
  .res-hero {
    background-color: var(--color-primary);
    padding-block: 72px 64px;
  }

  .res-hero__content {
    max-width: 680px;
  }

  .res-hero__content h1 {
    color: var(--color-white);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 16px;
  }

  .res-hero__lead {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.88);
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* Featured resources */
  .resources-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .resource-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-secondary);
    border-radius: var(--radius-card);
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .resource-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card);
  }

  .resource-card__icon {
    color: var(--color-primary);
    margin-bottom: 16px;
  }

  .resource-card__title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .resource-card__desc {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: 20px;
    flex: 1;
  }

  .resource-card__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    border: 1px solid var(--color-primary);
    border-radius: var(--radius-btn);
    padding: 8px 14px;
    transition: background-color var(--transition), color var(--transition);
    align-self: flex-start;
  }

  .resource-card__link:hover {
    background-color: var(--color-primary);
    color: var(--color-white);
  }

  .resource-card__link--disabled {
    opacity: 0.45;
    cursor: not-allowed;
    pointer-events: none;
    color: var(--color-muted);
    border-color: var(--color-secondary);
  }

  /* Available resources */
  .available-inner {
    max-width: 680px;
  }

  .resource-links {
    list-style: none;
    padding: 0;
    margin-bottom: 28px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .resource-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 16px 20px;
    background-color: var(--color-white);
    border: 1px solid var(--color-secondary);
    border-radius: var(--radius-btn);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .resource-link:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card);
  }

  .resource-link__icon {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .resource-note {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.6;
  }

  .resource-note svg {
    color: var(--color-primary);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .resource-note p {
    margin-bottom: 0;
  }

  .resource-note a {
    color: var(--color-primary);
    font-weight: 500;
  }

  @media (max-width: 1024px) {
    .resources-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .resources-grid { grid-template-columns: 1fr; }
  }
</style>
