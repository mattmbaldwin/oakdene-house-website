---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CTABand from '../../../components/CTABand.astro';

const opportunities = [
  'Team volunteering days',
  'Support for community program activities',
  'Donation drives or practical project support',
  'Partnership opportunities linked to skills or service delivery',
];
---

<BaseLayout
  title="Corporate Volunteering — Oakdene House Foundation"
  description="Bring your team to Oakdene House Foundation for corporate volunteering days or community partnerships. Based in Fairfield, Western Sydney."
  ogImage="/images/volunteers/oakdene-volunteer-kitchen-3a.png"
>

  <!-- HERO -->
  <section class="corp-hero" aria-label="Corporate Volunteering">
    <div class="corp-hero__overlay" aria-hidden="true"></div>
    <div class="container corp-hero__content">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <a href="/community-programs/">Community Programs</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <a href="/community-programs/volunteering/">Volunteering</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span aria-current="page">Corporate Volunteering</span>
      </nav>
      <h1>Corporate Volunteering</h1>
      <p class="corp-hero__lead">A practical way for organisations to support the local community with purpose and impact.</p>
    </div>
  </section>

  <!-- OVERVIEW -->
  <section class="section" aria-labelledby="corp-overview-heading">
    <div class="container">
      <div class="split">
        <div>
          <div class="section-heading">
            <p class="section-heading__eyebrow">About This Program</p>
            <h2 id="corp-overview-heading">Make it meaningful for your team</h2>
          </div>
          <p>Corporate volunteering offers organisations a practical way to support the local community while building team connection and purpose. Oakdene House can work with businesses and groups to create volunteering opportunities that are useful, well-organised and meaningful.</p>
          <p>Whether it is a one-day volunteering event or an ongoing partnership, we will work with you to find the right fit.</p>

          <h3 class="opps-heading">Potential opportunities</h3>
          <ul class="opps-list">
            {opportunities.map(o => <li>{o}</li>)}
          </ul>
        </div>
        <div class="corp-aside">
          <div class="corp-image">
            <img src="/images/kitchen/oakdene-kitchen-volunteers-wrappimg-bread.jpg" alt="Volunteers working together at Oakdene" loading="lazy" />
          </div>
          <div class="contact-prompt">
            <h3>Get in touch</h3>
            <p>If your organisation is interested in supporting Oakdene House through volunteering or partnership, please contact us to discuss suitable options.</p>
            <div class="btn-group">
              <a href="/contact/" class="btn btn--primary">Partnership Enquiry</a><!-- TODO: Replace with live Jotform URL -->
              <a href="/contact/" class="btn btn--secondary">Contact Us</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY PARTNER WITH OAKDENE -->
  <section class="section section--tint" aria-labelledby="why-heading">
    <div class="container">
      <div class="why-inner">
        <div class="section-heading section-heading--center">
          <p class="section-heading__eyebrow">Why Oakdene?</p>
          <h2 id="why-heading">A genuine community impact</h2>
        </div>
        <div class="why-grid">
          <div class="why-item">
            <div class="why-item__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3>Trusted local charity</h3>
            <p>Oakdene House has served the Fairfield community since 2011, with a strong track record of practical and respectful support.</p>
          </div>
          <div class="why-item">
            <div class="why-item__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
            <h3>Structured and purposeful</h3>
            <p>We work with your organisation to ensure volunteering days are well-organised, rewarding, and genuinely useful.</p>
          </div>
          <div class="why-item">
            <div class="why-item__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h3>Team connection</h3>
            <p>Working together on something meaningful builds team morale and a shared sense of purpose beyond the workplace.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABand
    heading="Interested in a corporate partnership?"
    subheading="Contact our team to discuss how your organisation can get involved."
    primaryBtn={{ text: 'Partnership Enquiry', href: '/contact/' }}
    secondaryBtn={{ text: 'Contact Us', href: '/contact/' }}
    dark={true}
  />

</BaseLayout>

<style>
  .corp-hero {
    position: relative;
    min-height: 380px;
    background-image: url('/images/volunteers/oakdene-volunteer-kitchen-3a.png');
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: flex-end;
  }

  .corp-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,62,81,0.45) 0%, rgba(0,62,81,0.88) 100%);
  }

  .corp-hero__content {
    position: relative;
    z-index: 1;
    padding-block: 56px;
  }

  .corp-hero__content h1 { color: var(--color-white); margin-bottom: 10px; }

  .corp-hero__lead {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.88);
    margin-bottom: 0;
    max-width: 520px;
  }

  .opps-heading {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    margin: 24px 0 14px;
  }

  .opps-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 0;
    list-style: none;
  }

  .opps-list li {
    padding-left: 24px;
    position: relative;
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.55;
  }

  .opps-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-primary);
  }

  .corp-aside {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .corp-image {
    border-radius: var(--radius-card);
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .corp-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .contact-prompt {
    background-color: var(--color-tint);
    border-radius: var(--radius-card);
    border: 1px solid var(--color-secondary);
    padding: 24px;
  }

  .contact-prompt h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 10px;
  }

  .contact-prompt p {
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  /* Why */
  .why-inner {
    max-width: 860px;
    margin-inline: auto;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .why-item {
    background-color: var(--color-white);
    border-radius: var(--radius-card);
    padding: 24px;
    border: 1px solid var(--color-secondary);
  }

  .why-item__icon {
    color: var(--color-primary);
    margin-bottom: 12px;
  }

  .why-item h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 8px;
  }

  .why-item p {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .why-grid { grid-template-columns: 1fr; }
  }
</style>
