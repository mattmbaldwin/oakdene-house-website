---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTABand from '../components/CTABand.astro';

const donationFaqs = [
  {
    question: 'Is my donation tax-deductible?',
    answer: 'Yes — donations of $2 or more to Oakdene are tax-deductible.',
  },
  {
    question: 'How will I receive a receipt?',
    answer: "You'll receive a receipt by email immediately after your donation is processed.",
  },
  {
    question: 'How do I cancel a monthly donation?',
    answer: 'You can cancel anytime by emailing admin@oakdenehouse.org.au or using the cancellation link in your donation email.',
  },
  {
    question: 'Is my payment secure?',
    answer: 'Yes. Payments are processed by GiveNow, a registered Australian donations platform. Oakdene does not see or store your card details.',
  },
  {
    question: 'Can I donate in memory of someone?',
    answer: "Yes — there's a field on the donation form. We'll include the tribute in our records and any acknowledgement you request.",
  },
  {
    question: 'What percentage of my donation goes to services?',
    answer: 'Over 90% of donated funds go directly to service delivery — the Kitchen, counselling, programs, and community support.',
  },
];
---

<BaseLayout
  title="Support Oakdene House"
  description="Help Oakdene House provide practical, dignified support to people and families facing addiction, hardship and homelessness in Sydney. Donations of $2 or more are tax-deductible."
  ogImage="/images/hero/hero-support-us.png"
>

  <!-- HERO -->
  <Hero
    heading="Your support changes real lives"
    subheading="Every donation to Oakdene House goes directly into practical support for people and families in our community. Whether you give once or become a monthly supporter, your contribution helps someone take the next step."
    image="/images/hero/hero-support-us.png"
    imageAlt="Community members supported by Oakdene House Foundation"
    buttons={[]}
  />

  <!-- INTRO -->
  <section class="section" aria-labelledby="intro-heading">
    <div class="container intro-container">
      <h2 id="intro-heading" class="visually-hidden">About your donation</h2>
      <p class="intro-text">Oakdene House Foundation has been part of Sydney's recovery community for over 30 years. We provide free counselling, transitional housing, and community programs to people and families facing addiction, hardship and homelessness. Your donation keeps those services running.</p>
    </div>
  </section>

  <!-- DONATE + OTHER WAYS TO GIVE -->
  <section class="section section--tint" aria-labelledby="donate-heading">
    <div class="container">
      <h2 id="donate-heading" class="visually-hidden">Donate</h2>
      <div class="donate-columns">

        <!-- LEFT: GiveNow embed -->
        <div class="donate-embed-card">
          <!-- TODO: Replace this placeholder with GiveNow iframe embed once cause is approved. Embed code from GiveNow OrgHQ → Manage Causes → Support Oakdene House → Embed. -->
          <div class="givenow-placeholder">
            <h2>Donate now</h2>
            <p class="placeholder-message">Our secure donation form is being prepared. It will appear here as soon as our donation platform completes its final review (usually within 2 business days).</p>
            <p class="placeholder-detail">In the meantime, you can give via direct deposit, cheque, or workplace giving — see options on the right.</p>
          </div>
        </div>

        <!-- RIGHT: Other ways to give -->
        <aside class="donate-sidebar" aria-label="Other ways to give">
          <div class="donate-sidebar__inner">
            <h3 class="donate-sidebar__heading">Other ways to give</h3>

            <div class="give-method">
              <h4>Direct deposit</h4>
              <dl class="give-method__details">
                <dt>BSB</dt>
                <dd>[to be supplied]</dd>
                <dt>Account</dt>
                <dd>[to be supplied]</dd>
                <dt>Reference</dt>
                <dd>Your name</dd>
              </dl>
            </div>

            <div class="give-method">
              <h4>Cheque</h4>
              <p>Made payable to <strong>Oakdene House Foundation</strong> and posted to PO Box 988, Fairfield NSW 1860.</p>
            </div>

            <div class="give-method">
              <h4>Workplace giving</h4>
              <p>Many employers offer payroll giving and matched donation schemes. Contact <a href="mailto:admin@oakdenehouse.org.au">admin@oakdenehouse.org.au</a> and we'll help set it up.</p>
            </div>

            <div class="give-method">
              <h4>Leave a gift in your will</h4>
              <p>Including Oakdene in your will is a meaningful way to support people and families for generations to come. Get in touch for a confidential conversation.</p>
            </div>

            <div class="give-method give-method--last">
              <h4>Corporate partnership</h4>
              <p>Interested in a longer-term partnership? Reach out via our <a href="/contact/">contact form</a> or email <a href="mailto:admin@oakdenehouse.org.au">admin@oakdenehouse.org.au</a> directly.</p>
            </div>
          </div>
        </aside>

      </div>
    </div>
  </section>

  <!-- ASSURANCE -->
  <section class="section" aria-labelledby="assurance-heading">
    <div class="container assurance-container">
      <h2 id="assurance-heading" class="visually-hidden">Donation assurance</h2>
      <p class="assurance-text"><em>Every contribution — large or small — helps Oakdene keep our doors open, our kitchen running, and our counsellors available for the people who need them most.</em></p>
      <p class="assurance-text"><em>Donations of $2 or more are tax-deductible.</em></p>
      <p class="assurance-credentials">Registered Australian charity &middot; ABN 90 151 950 926 &middot; Donations processed securely by GiveNow</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--tint" aria-labelledby="faq-heading">
    <div class="container faq-container">
      <div class="section-heading">
        <h2 id="faq-heading">Frequently asked questions about donations</h2>
      </div>
      <FAQAccordion faqs={donationFaqs} />
    </div>
  </section>

  <!-- CTA -->
  <CTABand
    heading="Need to talk to someone first?"
    subheading="If you'd prefer to discuss a donation, partnership, or leave a gift in your will, our team is here to help."
    primaryBtn={{ text: 'Contact us', href: '/contact/' }}
    dark={false}
  />

</BaseLayout>

<style>
  /* ── Intro ───────────────────────────────────────────── */
  .intro-container {
    max-width: 760px;
    text-align: center;
  }

  .intro-text {
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--color-text);
  }

  /* ── Two-column donate layout ────────────────────────── */
  .donate-columns {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 32px;
    align-items: start;
  }

  /* Left: embed card — primary visual weight */
  .donate-embed-card {
    background: var(--color-white);
    border: 1px solid var(--color-secondary);
    border-left: 4px solid var(--color-primary);
    border-radius: 8px;
    padding: 48px;
    min-height: 500px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .givenow-placeholder h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 20px;
  }

  .placeholder-message {
    font-size: 1rem;
    font-style: italic;
    color: var(--color-muted);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .placeholder-detail {
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.65;
    margin-bottom: 0;
  }

  /* Right: sidebar — secondary, no shadow, no accent */
  .donate-sidebar__inner {
    background: var(--color-white);
    border-radius: 8px;
    padding: 28px;
  }

  .donate-sidebar__heading {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 20px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--color-secondary);
  }

  .give-method {
    padding-bottom: 16px;
    margin-bottom: 16px;
    border-bottom: 1px solid var(--color-tint);
  }

  .give-method--last {
    padding-bottom: 0;
    margin-bottom: 0;
    border-bottom: none;
  }

  .give-method h4 {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 6px;
  }

  .give-method p {
    font-size: 0.875rem;
    color: var(--color-text);
    line-height: 1.5;
    margin-bottom: 0;
  }

  .give-method p a {
    color: var(--color-primary);
    font-weight: 500;
    text-decoration: none;
    transition: color var(--transition);
  }

  .give-method p a:hover {
    color: var(--color-primary-hover);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .give-method__details {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 4px 16px;
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 0;
  }

  .give-method__details dt {
    font-weight: 600;
    color: var(--color-primary);
  }

  .give-method__details dd {
    color: var(--color-text);
    margin: 0;
  }

  /* ── Assurance ───────────────────────────────────────── */
  .assurance-container {
    max-width: 760px;
    text-align: center;
  }

  .assurance-text {
    font-size: 1.0625rem;
    color: var(--color-muted);
    line-height: 1.75;
    margin-bottom: 8px;
  }

  .assurance-credentials {
    font-size: 0.8125rem;
    color: var(--color-muted);
    margin-top: 20px;
    margin-bottom: 0;
    letter-spacing: 0.01em;
  }

  /* ── FAQ ─────────────────────────────────────────────── */
  .faq-container {
    max-width: 760px;
  }

  .faq-container .section-heading {
    margin-bottom: 32px;
  }

  .faq-container .section-heading h2 {
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0;
  }

  /* ── Accessibility ───────────────────────────────────── */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 900px) {
    .donate-columns {
      grid-template-columns: 1fr;
    }

    .donate-embed-card {
      min-height: 320px;
    }
  }

  @media (max-width: 640px) {
    .donate-embed-card {
      padding: 28px 24px;
    }

    .donate-sidebar__inner {
      padding: 24px 20px;
    }
  }
</style>
