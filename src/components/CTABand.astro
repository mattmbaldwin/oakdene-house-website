---
interface Button {
  text: string;
  href: string;
}

interface Props {
  heading: string;
  subheading?: string;
  primaryBtn?: Button;
  secondaryBtn?: Button;
  dark?: boolean;
}

const {
  heading,
  subheading,
  primaryBtn,
  secondaryBtn,
  dark = true,
} = Astro.props;
---

<section class={`cta-band ${dark ? 'cta-band--dark' : 'cta-band--tint'}`}>
  <div class="container cta-band__inner">
    <div class="cta-band__text">
      <h2 class="cta-band__heading">{heading}</h2>
      {subheading && <p class="cta-band__subheading">{subheading}</p>}
    </div>
    {(primaryBtn || secondaryBtn) && (
      <div class="btn-group cta-band__btns">
        {primaryBtn && (
          <a href={primaryBtn.href} class={dark ? 'btn btn--white' : 'btn btn--primary'}>
            {primaryBtn.text}
          </a>
        )}
        {secondaryBtn && (
          <a href={secondaryBtn.href} class={dark ? 'btn btn--white-outline' : 'btn btn--secondary'}>
            {secondaryBtn.text}
          </a>
        )}
      </div>
    )}
  </div>
</section>

<style>
  .cta-band {
    padding-block: 64px;
  }

  .cta-band--dark {
    background-color: var(--color-primary);
  }

  .cta-band--tint {
    background-color: var(--color-tint);
  }

  .cta-band__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    flex-wrap: wrap;
  }

  .cta-band__text {
    flex: 1;
    min-width: 240px;
  }

  .cta-band__heading {
    font-size: clamp(1.375rem, 3vw, 1.75rem);
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: 8px;
  }

  .cta-band--tint .cta-band__heading {
    color: var(--color-primary);
  }

  .cta-band__subheading {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 0;
    max-width: 520px;
  }

  .cta-band--tint .cta-band__subheading {
    color: var(--color-muted);
  }

  .cta-band__btns {
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .cta-band {
      padding-block: 48px;
    }

    .cta-band__inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
