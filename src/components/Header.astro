---
const pathname = Astro.url.pathname;

const navLinks = [
  { label: 'Home',               href: '/' },
  { label: 'About',              href: '/about/' },
  { label: 'Services',           href: '/services/' },
  { label: 'Community Programs', href: '/community-programs/' },
  { label: 'Volunteering',       href: '/volunteering/' },
  { label: 'Resources',          href: '/resources/' },
  { label: 'Service Directory',  href: '/service-directory/' },
  { label: 'Contact',            href: '/contact/' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="site-header" id="site-header">
  <div class="header-inner container">
    <a href="/" class="header-logo" aria-label="Oakdene House Foundation — home">
      <img
        src="/images/logos/oakdene-hero-logo.png"
        alt="Oakdene House Foundation"
        height="56"
      />
    </a>

    <nav class="header-nav" aria-label="Main navigation">
      <ul class="nav-list" role="list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={`nav-link ${isActive(link.href) ? 'nav-link--active' : ''}`}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-ctas">
      <a href="/support-us/" class="btn btn--donate btn--sm">Donate</a>
      <a href="/services/referral/" class="btn btn--primary btn--sm">Get Support</a>
      <a href="/need-help-now/" class="btn btn--secondary btn--sm">Need Help Now</a>
    </div>

    <button
      class="hamburger"
      id="hamburger"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-drawer"
    >
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
    </button>
  </div>
</header>

<!-- Mobile drawer -->
<div class="mobile-drawer" id="mobile-drawer" aria-hidden="true">
  <div class="mobile-drawer__inner">
    <nav aria-label="Mobile navigation">
      <ul class="mobile-nav-list" role="list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={`mobile-nav-link ${isActive(link.href) ? 'mobile-nav-link--active' : ''}`}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="mobile-drawer__ctas">
      <a href="/support-us/" class="btn btn--donate">Donate</a>
      <a href="/services/referral/" class="btn btn--primary">Get Support</a>
      <a href="/need-help-now/" class="btn btn--secondary">Need Help Now</a>
    </div>
  </div>
</div>
<div class="mobile-overlay" id="mobile-overlay" aria-hidden="true"></div>

<style>
  /* ---- Header shell ---- */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-white);
    border-bottom: 1px solid transparent;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .site-header.scrolled {
    border-bottom-color: var(--color-secondary);
    box-shadow: 0 2px 12px rgba(0, 62, 81, 0.06);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 24px;
    height: 72px;
  }

  /* ---- Logo ---- */
  .header-logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .header-logo img {
    height: 56px;
    width: auto;
    object-fit: contain;
  }

  /* ---- Desktop nav ---- */
  .header-nav {
    flex: 1;
  }

  .nav-list {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    align-items: center;
  }

  .nav-link {
    display: block;
    padding: 6px 10px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    border-radius: 4px;
    text-decoration: none;
    transition: color var(--transition), background-color var(--transition);
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--color-primary);
    background-color: var(--color-tint);
  }

  .nav-link--active {
    color: var(--color-primary);
    font-weight: 600;
  }

  /* ---- Header CTAs ---- */
  .header-ctas {
    display: flex;
    gap: 10px;
    flex-shrink: 0;
  }

  .btn--sm {
    padding: 9px 18px;
    font-size: 0.875rem;
  }

  /* ---- Donate button ---- */
  .btn--donate {
    background-color: #B85A00;
    color: #ffffff;
    border-color: #B85A00;
  }

  .btn--donate:hover {
    background-color: #993D00;
    border-color: #993D00;
    color: #ffffff;
  }

  /* ---- Hamburger ---- */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 8px;
    border-radius: var(--radius-btn);
    background: none;
    border: none;
    cursor: pointer;
    margin-left: auto;
    flex-shrink: 0;
  }

  .hamburger__bar {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-primary);
    border-radius: 2px;
    transition: transform var(--transition), opacity var(--transition);
    transform-origin: center;
  }

  .hamburger.is-open .hamburger__bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .hamburger.is-open .hamburger__bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .hamburger.is-open .hamburger__bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ---- Mobile drawer ---- */
  .mobile-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(320px, 85vw);
    background-color: var(--color-white);
    z-index: 200;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: -4px 0 24px rgba(0, 62, 81, 0.12);
  }

  .mobile-drawer.is-open {
    transform: translateX(0);
  }

  .mobile-drawer__inner {
    padding: 80px 28px 40px;
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow-y: auto;
  }

  .mobile-nav-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 32px;
  }

  .mobile-nav-link {
    display: block;
    padding: 12px 14px;
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
    border-radius: 6px;
    text-decoration: none;
    transition: color var(--transition), background-color var(--transition);
  }

  .mobile-nav-link:hover,
  .mobile-nav-link--active {
    color: var(--color-primary);
    background-color: var(--color-tint);
    font-weight: 600;
  }

  .mobile-drawer__ctas {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: auto;
  }

  .mobile-drawer__ctas .btn {
    justify-content: center;
    text-align: center;
  }

  /* ---- Overlay ---- */
  .mobile-overlay {
    position: fixed;
    inset: 0;
    background-color: rgba(0, 62, 81, 0.4);
    z-index: 150;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .mobile-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .header-nav,
    .header-ctas {
      display: none;
    }

    .hamburger {
      display: flex;
    }
  }
</style>

<script>
  // Scroll: add .scrolled class
  const header = document.getElementById('site-header');
  const onScroll = () => {
    if (header) header.classList.toggle('scrolled', window.scrollY > 8);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile drawer toggle
  const hamburger = document.getElementById('hamburger');
  const drawer = document.getElementById('mobile-drawer');
  const overlay = document.getElementById('mobile-overlay');

  function openMenu() {
    hamburger?.classList.add('is-open');
    drawer?.classList.add('is-open');
    overlay?.classList.add('is-open');
    hamburger?.setAttribute('aria-expanded', 'true');
    drawer?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    hamburger?.classList.remove('is-open');
    drawer?.classList.remove('is-open');
    overlay?.classList.remove('is-open');
    hamburger?.setAttribute('aria-expanded', 'false');
    drawer?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.classList.contains('is-open');
    isOpen ? closeMenu() : openMenu();
  });

  overlay?.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
