<style>
  .site-footer {
    background-color: var(--color-primary);
    color: rgba(255, 255, 255, 0.85);
  }

  /* 4px top accent border */
  .footer-top-border {
    height: 4px;
    background-color: #C6D6E3;
  }

  /* ---- Main grid ---- */
  .footer-main {
    padding-block: 64px 52px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 40px;
  }

  /* ---- Column headings ---- */
  .footer-col__heading {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-white);
    margin-bottom: 18px;
  }

  /* ---- Nav link lists ---- */
  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 11px;
  }

  .footer-links a {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.72);
    text-decoration: none;
    transition: color var(--transition);
    line-height: 1.35;
  }

  .footer-links a:hover {
    color: var(--color-white);
  }

  /* "All X" links — slightly brighter to signal overview */
  .footer-links a.footer-link--all {
    color: rgba(255, 255, 255, 0.88);
    font-weight: 500;
    margin-top: 2px;
  }

  /* ---- Contact column ---- */
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 13px;
  }

  .footer-contact li {
    display: flex;
    gap: 9px;
    align-items: flex-start;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.45;
  }

  .footer-contact svg {
    flex-shrink: 0;
    margin-top: 2px;
    opacity: 0.65;
  }

  .footer-contact a {
    color: rgba(255, 255, 255, 0.72);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer-contact a:hover {
    color: var(--color-white);
  }

  /* ---- Bottom row ---- */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    padding-block: 20px;
  }

  .footer-bottom__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }

  /* Left: logo + legal text */
  .footer-bottom__left {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    min-width: 0;
  }

  .footer-bottom-logo img {
    height: 28px;
    width: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.7;
    display: block;
    flex-shrink: 0;
  }

  .footer-bottom__legal {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.48);
  }

  .footer-bottom__legal span {
    white-space: nowrap;
  }

  .footer-bottom__legal a {
    color: rgba(255, 255, 255, 0.52);
    text-decoration: none;
    white-space: nowrap;
    transition: color var(--transition);
  }

  .footer-bottom__legal a:hover {
    color: var(--color-white);
  }

  .footer-dot {
    color: rgba(255, 255, 255, 0.3);
    font-size: 0.75rem;
    line-height: 1;
  }

  /* Right: copyright + social */
  .footer-bottom__right {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }

  .footer-copyright {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.48);
    margin-bottom: 0;
    white-space: nowrap;
  }

  /* Social icons */
  .footer-social {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.22);
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    transition: background-color var(--transition), color var(--transition), border-color var(--transition);
  }

  .social-link:hover {
    background-color: rgba(255, 255, 255, 0.1);
    color: var(--color-white);
    border-color: rgba(255, 255, 255, 0.45);
  }

  /* ---- Responsive ---- */

  /* Tablet: 3 columns */
  @media (max-width: 1100px) {
    .footer-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 36px;
    }
  }

  /* Small tablet: 2 columns */
  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }

    .footer-main {
      padding-block: 48px 40px;
    }
  }

  /* Mobile: single column, bottom row stacks centred */
  @media (max-width: 420px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .footer-bottom__inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 14px;
    }

    .footer-bottom__left {
      flex-direction: column;
      align-items: center;
      gap: 10px;
    }

    .footer-bottom__legal {
      justify-content: center;
    }

    .footer-bottom__right {
      flex-direction: column;
      align-items: center;
      gap: 10px;
    }

    .footer-copyright {
      white-space: normal;
      text-align: center;
    }
  }
</style>
