---
interface Row {
  label: string;
  value: string;
}

interface Props {
  rows: Row[];
  caption?: string;
}

const { rows, caption } = Astro.props;
---

<div class="info-table-wrap">
  <table class="info-table" aria-label={caption}>
    {caption && <caption class="info-table__caption">{caption}</caption>}
    <tbody>
      {rows.map(row => (
        <tr>
          <th scope="row">{row.label}</th>
          <td set:html={row.value} />
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .info-table-wrap {
    border-radius: var(--radius-card);
    overflow: hidden;
    border: 1px solid var(--color-secondary);
  }

  .info-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
  }

  .info-table__caption {
    font-size: 0.8125rem;
    font-weight: 600;
    text-align: left;
    color: var(--color-muted);
    padding: 12px 20px;
    background-color: var(--color-tint);
    border-bottom: 1px solid var(--color-secondary);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .info-table tr {
    border-bottom: 1px solid var(--color-secondary);
  }

  .info-table tr:last-child {
    border-bottom: none;
  }

  .info-table tr:nth-child(even) {
    background-color: var(--color-tint);
  }

  .info-table th,
  .info-table td {
    padding: 15px 20px;
    text-align: left;
    vertical-align: top;
  }

  .info-table th {
    font-weight: 600;
    color: var(--color-primary);
    width: 35%;
    white-space: nowrap;
  }

  .info-table td {
    color: var(--color-text);
    line-height: 1.55;
  }

  @media (max-width: 480px) {
    .info-table th,
    .info-table td {
      display: block;
      width: 100%;
      padding: 8px 16px;
    }

    .info-table th {
      padding-top: 14px;
      padding-bottom: 4px;
      font-size: 0.8125rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .info-table td {
      padding-bottom: 14px;
    }
  }
</style>
